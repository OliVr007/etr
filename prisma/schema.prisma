generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  full_name String @db.Char(50)
  user_name String @db.Char(8)
  password  String @db.Char(72)
}
