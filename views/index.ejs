<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/index.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/" class="active">Áttekintés</a></li>
					<li><a href="/courses">Kurzusaim</a></li>
					<li><a href="/tasks">Feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container">
			<section class="welcome-section">
				<h2>Üdvözöllek!</h2>
				<p>Ma: 2023. október 12., szerda</p>
			</section>

			<div class="dashboard-grid">
				<!-- Legutóbbi értékelés -->
				<div class="grid-card">
					<div class="card-header">
						<h3>Legutóbbi értékelés</h3>
						<div class="card-badge">3 db</div>
					</div>
					<div class="card-content">
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Matematika ZH</div>
								<div class="item-date">2023. október 12.</div>
							</div>
							<div class="item-value">85%</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Programozás beadandó</div>
								<div class="item-date">2023. október 8.</div>
							</div>
							<div class="item-value">92%</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Adatbázisok teszt</div>
								<div class="item-date">2023. október 5.</div>
							</div>
							<div class="item-value">78%</div>
						</div>
					</div>
					<div class="card-footer">
						<a href="#" class="view-all">Összes értékelés →</a>
					</div>
				</div>

				<!-- Legutóbbi mulasztás -->
				<div class="grid-card">
					<div class="card-header">
						<h3>Legutóbbi mulasztás</h3>
						<div class="card-badge warning">4 óra</div>
					</div>
					<div class="card-content">
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Adatbázisok előadás</div>
								<div class="item-date">2023. október 10.</div>
							</div>
							<div class="item-value">1 óra</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Programozás gyakorlat</div>
								<div class="item-date">2023. október 5.</div>
							</div>
							<div class="item-value">2 óra</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Hálózatok előadás</div>
								<div class="item-date">2023. szeptember 28.</div>
							</div>
							<div class="item-value">1 óra</div>
						</div>
					</div>
					<div class="card-footer">
						<a href="#" class="view-all">Összes mulasztás →</a>
					</div>
				</div>

				<!-- Legutóbbi feljegyzések -->
				<div class="grid-card">
					<div class="card-header">
						<h3>Legutóbbi feljegyzések</h3>
						<div class="card-badge">3 db</div>
					</div>
					<div class="card-content">
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Matematika - javítás</div>
								<div class="item-date">2023. október 12.</div>
							</div>
							<div class="item-desc">ZH eredménye felülvizsgálatra került, új értékelés: 85%</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Programozás - dicséret</div>
								<div class="item-date">2023. október 8.</div>
							</div>
							<div class="item-desc">Kiemelkedő teljesítmény a legutóbbi projektben</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Figyelmeztetés</div>
								<div class="item-date">2023. október 5.</div>
							</div>
							<div class="item-desc">További mulasztások esetén vizsgajogosultság veszélybe kerül</div>
						</div>
					</div>
					<div class="card-footer">
						<a href="#" class="view-all">Összes feljegyzés →</a>
					</div>
				</div>

				<!-- Következő bejelentett dolgozatok -->
				<div class="grid-card">
					<div class="card-header">
						<h3>Következő dolgozatok</h3>
						<div class="card-badge urgent">3 db</div>
					</div>
					<div class="card-content">
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Operációs rendszerek</div>
								<div class="item-date">2023. október 25.</div>
							</div>
							<div class="item-type">Zárthelyi dolgozat</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Mesterséges intelligencia</div>
								<div class="item-date">2023. október 30.</div>
							</div>
							<div class="item-type">Beadandó feladat</div>
						</div>
						<div class="card-item">
							<div class="item-main">
								<div class="item-title">Adatbázisok</div>
								<div class="item-date">2023. november 5.</div>
							</div>
							<div class="item-type">Gyakorlati vizsga</div>
						</div>
					</div>
					<div class="card-footer">
						<a href="#" class="view-all">Összes dolgozat →</a>
					</div>
				</div>
			</div>
		</main>
	</body>
</html>
