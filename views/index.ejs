<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/index.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<img src="/icons/icon-128.webp" alt="" />
					<div class="user-info">
						<a href="/logout"><img src="/icons/logouticon.svg" alt="Kijelentkezés gomb" title="Kijelentkezés" /></a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/" class="active">Áttekintés</a></li>
					<li><a href="/courses">Kurzusaim</a></li>
					<li><a href="/tasks">Feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container">
			<section class="welcome-section">
				<center><h2>Üdvözöllek <%= full_name %>!</h2></center>
			</section>
			<div class="dashboard-grid">
				<div class="grid-elem">
					<h3>Legutóbbi értékelés</h3>
					<div class="elem-tartalom">
						<div class="ertekeles-elem">
							<div class="ertekeles-cim">Matematika ZH</div>
							<div class="ertekeles-jegy">85%</div>
							<div class="ertekeles-datum">2023. október 12.</div>
						</div>
						<div class="ertekeles-elem">
							<div class="ertekeles-cim">Programozás beadandó</div>
							<div class="ertekeles-jegy">92%</div>
							<div class="ertekeles-datum">2023. október 8.</div>
						</div>
						<div class="ertekeles-elem">
							<div class="ertekeles-cim">Adatbázisok teszt</div>
							<div class="ertekeles-jegy">78%</div>
							<div class="ertekeles-datum">2023. október 5.</div>
						</div>
					</div>
				</div>
				<div class="grid-elem">
					<h3>Legutóbbi mulasztás</h3>
					<div class="elem-tartalom">
						<div class="mulasztas-elem">
							<div class="mulasztas-kurzus">Adatbázisok előadás</div>
							<div class="mulasztas-datum">2023. október 10.</div>
							<div class="mulasztas-szam">1 óra</div>
						</div>
						<div class="mulasztas-elem">
							<div class="mulasztas-kurzus">Programozás gyakorlat</div>
							<div class="mulasztas-datum">2023. október 5.</div>
							<div class="mulasztas-szam">2 óra</div>
						</div>
						<div class="mulasztas-elem">
							<div class="mulasztas-kurzus">Hálózatok előadás</div>
							<div class="mulasztas-datum">2023. szeptember 28.</div>
							<div class="mulasztas-szam">1 óra</div>
						</div>
					</div>
				</div>
				<div class="grid-elem">
					<h3>Legutóbbi feljegyzések</h3>
					<div class="elem-tartalom">
						<div class="feljegyzes-elem">
							<div class="feljegyzes-cim">Matematika - javítás</div>
							<div class="feljegyzes-tartalom">ZH eredménye felülvizsgálatra került, új értékelés: 85%</div>
						</div>
						<div class="feljegyzes-elem">
							<div class="feljegyzes-cim">Programozás - dicséret</div>
							<div class="feljegyzes-tartalom">Kiemelkedő teljesítmény a legutóbbi projektben</div>
						</div>
						<div class="feljegyzes-elem">
							<div class="feljegyzes-cim">Figyelmeztetés</div>
							<div class="feljegyzes-tartalom">További mulasztások esetén vizsgajogosultság veszélybe kerül</div>
						</div>
					</div>
				</div>

				<!-- Következő bejelentett dolgozatok -->
				<div class="grid-elem">
					<h3>Következő bejelentett dolgozatok</h3>
					<div class="elem-tartalom">
						<div class="dolgozat-elem">
							<div class="dolgozat-kurzus">Operációs rendszerek</div>
							<div class="dolgozat-tipus">Zárthelyi dolgozat</div>
							<div class="dolgozat-datum">2023. október 25.</div>
						</div>
						<div class="dolgozat-elem">
							<div class="dolgozat-kurzus">Mesterséges intelligencia</div>
							<div class="dolgozat-tipus">Beadandó feladat</div>
							<div class="dolgozat-datum">2023. október 30.</div>
						</div>
						<div class="dolgozat-elem">
							<div class="dolgozat-kurzus">Adatbázisok</div>
							<div class="dolgozat-tipus">Gyakorlati vizsga</div>
							<div class="dolgozat-datum">2023. november 5.</div>
						</div>
					</div>
				</div>
			</div>
		</main>
	</body>
</html>
