<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/teacher/teacher-homework.css" />
		<link rel="stylesheet" href="/css/mobile.css" />
		<title>Házi feladatok - Tanári felület</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<button class="hamburger-btn" aria-label="Menü">
						<div class="hamburger-icon">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</button>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/teacher">Áttekintés</a></li>
					<li><a href="/teacher/grading">Értékelések</a></li>
					<li><a href="/teacher/homework" class="active">Házi feladatok</a></li>
					<li><a href="/teacher/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container homework-container">
			<div class="homework-header">
				<h1>Házi feladatok</h1>
				<button class="new-homework-btn" onclick="openNewHomeworkModal()">+ Új házi feladat</button>
			</div>

			<div class="homework-tabs">
				<button class="tab active" data-tab="pending">Beadásra vár</button>
				<button class="tab" data-tab="submitted">Ellenőrzésre vár</button>
				<button class="tab" data-tab="accepted">Elfogadott</button>
			</div>

			<div class="homework-list" id="homework-list">
				<p style="text-align: center; color: #666; padding: 2rem">Betöltés...</p>
			</div>
		</main>

		<!-- Modal -->
		<div class="modal" id="newHomeworkModal">
			<div class="modal-content">
				<div class="modal-header">
					<h2>Új házi feladat</h2>
					<button class="close-btn" onclick="closeModal()">&times;</button>
				</div>
				<form id="homeworkForm">
					<div class="form-group">
						<label for="assignment_type">Kinek szól?</label>
						<select id="assignment_type" required>
							<option value="">— Válassz —</option>
							<option value="class">Egész osztálynak</option>
							<option value="student">Egy diáknak</option>
						</select>
					</div>

					<div class="form-group" id="class_group" style="display: none">
						<label for="class_id">Osztály</label>
						<select id="class_id"></select>
					</div>

					<div class="form-group" id="student_group" style="display: none">
						<label for="student_id">Diák</label>
						<select id="student_id"></select>
					</div>

					<div class="form-group" id="subject_group" style="display: none">
						<label for="subject_id">Tantárgy</label>
						<select id="subject_id" required>
							<option value="">— Előbb válassz osztályt —</option>
						</select>
					</div>

					<div class="form-group">
						<label for="title">Cím</label>
						<input type="text" id="title" placeholder="pl. Másodfokú egyenletek" required />
					</div>

					<div class="form-group">
						<label for="description">Leírás</label>
						<textarea id="description" rows="4" placeholder="Feladat részletei..." required></textarea>
					</div>

					<div class="form-group">
						<label for="due_date">Határidő</label>
						<input type="date" id="due_date" required />
					</div>

					<div class="form-actions">
						<button type="button" class="secondary-btn" onclick="closeModal()">Mégse</button>
						<button type="submit" class="primary-btn">Létrehozás</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Mobil navigáció -->
		<div class="mobile-nav-overlay"></div>
		<div class="mobile-nav-drawer">
			<nav class="mobile-nav-links">
				<a href="/teacher"><span class="nav-icon">🏠</span> Áttekintés</a>
				<a href="/teacher/grading"><span class="nav-icon">📊</span> Értékelések</a>
				<a href="/teacher/homework" class="active"><span class="nav-icon">📝</span> Házi feladatok</a>
				<a href="/teacher/messages"><span class="nav-icon">✉️</span> Üzenetek</a>
			</nav>
			<div class="mobile-nav-logout">
				<a href="/logout">
					<img src="/icons/logouticon.svg" alt="Kijelentkezés" />
					Kijelentkezés
				</a>
			</div>
		</div>

		<script src="/js/mobile.js"></script>
		<script>
			let classes = [];
			let classStudents = {};
			let allHomeworks = [];

			function escapeHtml(text) {
				if (!text) return "";
				const div = document.createElement("div");
				div.textContent = text;
				return div.innerHTML;
			}

			function toggleExpand(contentId, button, event) {
				event.stopPropagation();
				const content = document.getElementById(contentId);
				const isExpanded = content.classList.contains("expanded");

				if (isExpanded) {
					content.classList.remove("expanded");
					content.classList.add("collapsed");
					button.classList.remove("expanded");
					button.querySelector("span").textContent = "Továbbiak";
				} else {
					content.classList.remove("collapsed");
					content.classList.add("expanded");
					button.classList.add("expanded");
					button.querySelector("span").textContent = "Kevesebb";
				}
			}

			document.addEventListener("DOMContentLoaded", () => {
				loadClasses();
				loadHomeworks();
				setupTabs();
			});

			async function loadClasses() {
				try {
					const resp = await fetch("/api/teacher/classes");
					const data = await resp.json();
					classes = data.classes || [];

					const classSelect = document.getElementById("class_id");
					classSelect.innerHTML = '<option value="">— Válassz osztályt —</option>';
					classes.forEach((cls) => {
						classSelect.innerHTML += `<option value="${cls.id}">${cls.name}</option>`;
					});
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			async function loadSubjectsForClass(classId) {
				const subjectSelect = document.getElementById("subject_id");

				if (!classId) {
					subjectSelect.innerHTML = '<option value="">— Előbb válassz osztályt —</option>';
					return;
				}

				try {
					const resp = await fetch(`/api/teacher/class/${classId}/subjects`);
					const data = await resp.json();
					const subjects = data.subjects || [];

					subjectSelect.innerHTML = '<option value="">— Válassz tantárgyat —</option>';
					subjects.forEach((sub) => {
						subjectSelect.innerHTML += `<option value="${sub.id}">${sub.subject_name}</option>`;
					});
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			async function loadStudentsForClass(classId) {
				if (classStudents[classId]) return classStudents[classId];

				try {
					const resp = await fetch(`/api/teacher/class/${classId}/students`);
					const data = await resp.json();
					classStudents[classId] = data.students || [];
					return classStudents[classId];
				} catch (error) {
					console.error("Hiba:", error);
					return [];
				}
			}

			async function loadHomeworks() {
				try {
					const resp = await fetch("/api/teacher/homeworks");
					const data = await resp.json();
					allHomeworks = data.homeworks || [];

					const submittedCount = allHomeworks.reduce((sum, hw) => {
						return sum + hw.submissions.filter((s) => s.status === "submitted").length;
					}, 0);

					const submittedTab = document.querySelector(".tab[data-tab='submitted']");
					const existingBadge = submittedTab.querySelector(".tab-alert");
					if (existingBadge) existingBadge.remove();

					if (submittedCount > 0) {
						submittedTab.innerHTML = `Ellenőrzésre vár <span class="tab-alert">${submittedCount}</span>`;
					} else {
						submittedTab.textContent = "Ellenőrzésre vár";
					}

					renderHomeworks();
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			function renderHomeworks() {
				const container = document.getElementById("homework-list");
				const activeTab = document.querySelector(".tab.active").dataset.tab;

				const statusText = {
					pending: "Beadásra vár",
					submitted: "Ellenőrzésre vár",
					accepted: "Elfogadott",
				};

				let html = "";
				let itemIndex = 0;

				allHomeworks.forEach((hw) => {
					hw.submissions.forEach((sub) => {
						if (sub.status !== activeTab) return;

						const dueDate = new Date(hw.due_date).toLocaleDateString("hu-HU", {
							year: "numeric",
							month: "long",
							day: "numeric",
						});

						const contentId = "homework-content-" + itemIndex;
						const needsExpand = hw.description && hw.description.length > 150;
						const subjectName = hw.subject || "Ismeretlen tantárgy";
						itemIndex++;

						const recipientHtml = hw.class_name
							? `<div class="homework-recipient">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
										<path d="M10 9a3 3 0 100-6 3 3 0 000 6zM6 8a2 2 0 11-4 0 2 2 0 014 0zM1.49 15.326a.78.78 0 01-.358-.442 3 3 0 014.308-3.516 6.484 6.484 0 00-1.905 3.959c-.023.222-.014.442.025.654a4.97 4.97 0 01-2.07-.655zM16.44 15.98a4.97 4.97 0 002.07-.654.78.78 0 00.357-.442 3 3 0 00-4.308-3.517 6.484 6.484 0 011.907 3.96 2.32 2.32 0 01-.026.654zM18 8a2 2 0 11-4 0 2 2 0 014 0zM5.304 16.19a.844.844 0 01-.277-.71 5 5 0 019.947 0 .843.843 0 01-.277.71A6.975 6.975 0 0110 18a6.974 6.974 0 01-4.696-1.81z" />
									</svg>
									<span>${escapeHtml(hw.class_name)} (egész osztály)</span>
								</div>`
							: `<div class="homework-recipient">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
										<path d="M10 8a3 3 0 100-6 3 3 0 000 6zM3.465 14.493a1.23 1.23 0 00.41 1.412A9.957 9.957 0 0010 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 00-13.074.003z" />
									</svg>
									<span>${escapeHtml(sub.student_name)}</span>
								</div>`;

						html += `
							<div class="homework-item">
								<div class="homework-item-header">
									<div class="homework-meta">
										<span class="homework-subject">${escapeHtml(subjectName)}</span>
										<span class="homework-date">Határidő: ${dueDate}</span>
									</div>
									<div class="homework-badge ${sub.status}">${statusText[sub.status]}</div>
								</div>
								<h3 class="homework-title">${escapeHtml(hw.title)}</h3>
								${recipientHtml}
								${
									hw.description
										? `
									<div class="homework-content ${needsExpand ? "collapsed" : ""}" id="${contentId}">
										<p>${escapeHtml(hw.description)}</p>
									</div>
									${
										needsExpand
											? `
										<button class="expand-btn" onclick="toggleExpand('${contentId}', this, event)">
											<span>Továbbiak</span>
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
											</svg>
										</button>
									`
											: ""
									}
								`
										: ""
								}
								${
									sub.status === "submitted"
										? `
									<div class="homework-actions">
										<button class="accept-btn" onclick="acceptHomework(${sub.id})">
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
											</svg>
											Elfogadás
										</button>
									</div>
								`
										: ""
								}
							</div>
						`;
					});
				});

				if (!html) {
					const emptyTexts = {
						pending: { title: "Nincs beadásra váró házi feladat", desc: "Az új házi feladatok itt fognak megjelenni" },
						submitted: { title: "Nincs ellenőrzésre váró beadás", desc: "A beadott házi feladatok itt fognak megjelenni" },
						accepted: { title: "Nincs elfogadott házi feladat", desc: "Az elfogadott beadások itt fognak megjelenni" },
					};

					html = `
						<div class="homework-empty">
							<div class="homework-empty-icon">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
								</svg>
							</div>
							<h3>${emptyTexts[activeTab].title}</h3>
							<p>${emptyTexts[activeTab].desc}</p>
						</div>
					`;
				}

				container.innerHTML = html;
			}

			function setupTabs() {
				document.querySelectorAll(".tab").forEach((btn) => {
					btn.addEventListener("click", () => {
						document.querySelectorAll(".tab").forEach((b) => b.classList.remove("active"));
						btn.classList.add("active");
						renderHomeworks();
					});
				});
			}

			function openNewHomeworkModal() {
				document.getElementById("newHomeworkModal").style.display = "flex";
			}

			function closeModal() {
				document.getElementById("newHomeworkModal").style.display = "none";
				document.getElementById("homeworkForm").reset();
				document.getElementById("class_group").style.display = "none";
				document.getElementById("student_group").style.display = "none";
				document.getElementById("subject_group").style.display = "none";
				document.getElementById("subject_id").innerHTML = '<option value="">— Előbb válassz osztályt —</option>';
			}

			document.getElementById("assignment_type").addEventListener("change", function () {
				const type = this.value;
				const classGroup = document.getElementById("class_group");
				const studentGroup = document.getElementById("student_group");
				const subjectGroup = document.getElementById("subject_group");

				if (type === "class") {
					classGroup.style.display = "block";
					studentGroup.style.display = "none";
					subjectGroup.style.display = "block";
					document.getElementById("class_id").required = true;
					document.getElementById("student_id").required = false;
				} else if (type === "student") {
					classGroup.style.display = "block";
					studentGroup.style.display = "block";
					subjectGroup.style.display = "block";
					document.getElementById("class_id").required = true;
					document.getElementById("student_id").required = true;
				} else {
					classGroup.style.display = "none";
					studentGroup.style.display = "none";
					subjectGroup.style.display = "none";
				}
			});

			document.getElementById("class_id").addEventListener("change", async function () {
				const classId = this.value;
				const studentSelect = document.getElementById("student_id");
				const assignmentType = document.getElementById("assignment_type").value;

				await loadSubjectsForClass(classId);

				if (assignmentType === "student" && classId) {
					const students = await loadStudentsForClass(classId);
					studentSelect.innerHTML = '<option value="">— Válassz diákot —</option>';
					students.forEach((s) => {
						studentSelect.innerHTML += `<option value="${s.id}">${s.last_name} ${s.first_name}</option>`;
					});
				}
			});

			document.getElementById("homeworkForm").addEventListener("submit", async function (e) {
				e.preventDefault();

				const type = document.getElementById("assignment_type").value;
				const data = {
					subject_id: document.getElementById("subject_id").value,
					title: document.getElementById("title").value,
					description: document.getElementById("description").value,
					due_date: document.getElementById("due_date").value,
				};

				if (type === "class") {
					data.class_id = document.getElementById("class_id").value;
				} else if (type === "student") {
					data.student_id = document.getElementById("student_id").value;
				}

				try {
					const resp = await fetch("/api/teacher/homework", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(data),
					});

					if (resp.ok) {
						closeModal();
						loadHomeworks();
						alert("Házi feladat létrehozva!");
					} else {
						alert("Hiba történt!");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt!");
				}
			});

			async function acceptHomework(submissionId) {
				try {
					const resp = await fetch(`/api/teacher/homework/accept/${submissionId}`, {
						method: "PUT",
					});

					if (resp.ok) {
						loadHomeworks();
					} else {
						alert("Hiba történt!");
					}
				} catch (error) {
					console.error("Hiba:", error);
				}
			}
		</script>
	</body>
</html>
