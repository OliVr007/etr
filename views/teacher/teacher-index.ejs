<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/teacher/teacher-index.css" />
		<title>Tanári felület - Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/teacher" class="active">Áttekintés</a></li>
					<li><a href="/teacher/classes">Osztályok</a></li>
					<li><a href="/teacher/grading">Értékelések</a></li>
					<li><a href="/teacher/schedule">Órarend</a></li>
					<li><a href="/teacher/homework">Házi feladatok</a></li>
					<li><a href="/teacher/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container">
			<section class="welcome-section">
				<h2>Üdvözöllek <%= first_name %>!</h2>
				<p>Ma: <%= new Date().toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' }) %></p>
			</section>

			<div class="carousel-container">
				<div class="carousel-track">
					<!-- 1. Mai órák -->
					<div class="carousel-slide">
						<div class="carousel-card">
							<div class="card-header">
								<h3>Mai órák</h3>
								<div class="card-badge"><%= todayLessons.length %> db</div>
							</div>
							<div class="card-content">
								<% if (todayLessons.length > 0) { %>
									<% todayLessons.forEach((lesson, index) => { %>
										<% 
											let status = "";
											const now = new Date();
											const currentHour = now.getHours();
											const currentMin = now.getMinutes();
											const [startHour, startMin] = lesson.start_time.split(':').map(Number);
											const [endHour, endMin] = lesson.end_time.split(':').map(Number);
											
											const currentMinutes = currentHour * 60 + currentMin;
											const startMinutes = startHour * 60 + startMin;
											const endMinutes = endHour * 60 + endMin;
											
											if (currentMinutes < startMinutes) {
												if (index === 0 || (index > 0 && currentMinutes >= (todayLessons[index-1] ? parseInt(todayLessons[index-1].end_time.split(':')[0]) * 60 + parseInt(todayLessons[index-1].end_time.split(':')[1]) : 0))) {
													status = "Következő";
												} else {
													status = "Később";
												}
											} else if (currentMinutes >= startMinutes && currentMinutes <= endMinutes) {
												status = "Folyamatban";
											} else {
												status = "Befejezett";
											}
										%>
										<div class="card-item">
											<div class="item-main">
												<div class="item-title"><%= lesson.subject_name %> - <%= lesson.class_name %></div>
												<div class="item-date"><%= lesson.start_time %> - <%= lesson.end_time %> • <%= lesson.room_number %> terem</div>
											</div>
											<div class="item-value"><%= status %></div>
										</div>
									<% }); %>
								<% } else { %>
									<div class="card-item">
										<div class="item-main">
											<div class="item-title">Nincs órád ma</div>
											<div class="item-date">Pihenj!</div>
										</div>
									</div>
								<% } %>
							</div>
							<div class="card-footer">
								<a href="/teacher/schedule" class="view-all">Teljes órarend →</a>
							</div>
						</div>
					</div>

					<!-- 2. Osztályok áttekintése -->
					<div class="carousel-slide">
						<div class="carousel-card">
							<div class="card-header">
								<h3>Osztályok áttekintése</h3>
								<div class="card-badge"><%= classesOverview.length %> osztály</div>
							</div>
							<div class="card-content">
								<% if (classesOverview.length > 0) { %>
									<% classesOverview.slice(0, 5).forEach(classData => { %>
										<div class="card-item">
											<div class="item-main">
												<div class="item-title"><%= classData.class_name %> - <%= classData.subject_name %></div>
												<div class="item-date"><%= classData.student_count %> tanuló • Átlag: <%= classData.average_grade %></div>
											</div>
											<div class="item-value"><%= classData.grade_label %></div>
										</div>
									<% }); %>
								<% } else { %>
									<div class="card-item">
										<div class="item-main">
											<div class="item-title">Még nincs hozzárendelt osztály</div>
											<div class="item-date">Hamarosan érkezik</div>
										</div>
									</div>
								<% } %>
							</div>
							<div class="card-footer">
								<a href="/teacher/classes" class="view-all">Összes osztály →</a>
							</div>
						</div>
					</div>

					<!-- 3. Legutóbbi üzenetek -->
					<div class="carousel-slide">
						<div class="carousel-card">
							<div class="card-header">
								<h3>Legutóbbi üzenetek</h3>
								<div class="card-badge"><%= recentMessages.length %> db</div>
							</div>
							<div class="card-content">
								<% if (recentMessages.length > 0) { %>
									<% recentMessages.forEach(msg => { %>
										<div class="card-item <%= !msg.is_read ? 'unread' : '' %>">
											<div class="item-main">
												<div class="item-title"><%= msg.sender_name %></div>
												<div class="item-date"><%= new Date(msg.sent_at).toLocaleDateString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric' }) %></div>
												<div class="item-desc"><%= msg.subject %>: <%= msg.content_preview %></div>
											</div>
										</div>
									<% }); %>
								<% } else { %>
									<div class="card-item">
										<div class="item-main">
											<div class="item-title">Nincs új üzenet</div>
											<div class="item-date">A beérkező mappád üres</div>
										</div>
									</div>
								<% } %>
							</div>
							<div class="card-footer">
								<a href="/teacher/messages" class="view-all">Összes üzenet →</a>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="carousel-controls">
				<button class="carousel-btn prev-btn">←</button>
				<div class="carousel-indicators">
					<div class="carousel-indicator active" data-index="0"></div>
					<div class="carousel-indicator" data-index="1"></div>
					<div class="carousel-indicator" data-index="2"></div>
				</div>
				<button class="carousel-btn next-btn">→</button>
			</div>
		</main>

		<script>
			document.addEventListener("DOMContentLoaded", function () {
				const track = document.querySelector(".carousel-track");
				const slides = Array.from(track.children);
				const nextButton = document.querySelector(".next-btn");
				const prevButton = document.querySelector(".prev-btn");
				const indicators = document.querySelectorAll(".carousel-indicator");

				const slideWidth = track.clientWidth;
				let currentIndex = 0;

				const setSlidePosition = (slide, index) => {
					slide.style.left = slideWidth * index + "px";
				};
				slides.forEach(setSlidePosition);

				const moveToSlide = (track, currentSlide, targetSlide) => {
					track.style.transform = "translateX(-" + targetSlide.style.left + ")";
					currentSlide = targetSlide;
					return currentSlide;
				};

				const updateIndicators = (currentIndex) => {
					indicators.forEach((indicator, index) => {
						if (index === currentIndex) {
							indicator.classList.add("active");
						} else {
							indicator.classList.remove("active");
						}
					});
				};

				nextButton.addEventListener("click", (e) => {
					const nextIndex = currentIndex < slides.length - 1 ? currentIndex + 1 : 0;
					const targetSlide = slides[nextIndex];
					moveToSlide(track, slides[currentIndex], targetSlide);
					currentIndex = nextIndex;
					updateIndicators(currentIndex);
				});

				prevButton.addEventListener("click", (e) => {
					const prevIndex = currentIndex > 0 ? currentIndex - 1 : slides.length - 1;
					const targetSlide = slides[prevIndex];
					moveToSlide(track, slides[currentIndex], targetSlide);
					currentIndex = prevIndex;
					updateIndicators(currentIndex);
				});

				indicators.forEach((indicator, index) => {
					indicator.addEventListener("click", (e) => {
						const targetSlide = slides[index];
						moveToSlide(track, slides[currentIndex], targetSlide);
						currentIndex = index;
						updateIndicators(currentIndex);
					});
				});

				window.addEventListener("resize", () => {
					const newSlideWidth = track.clientWidth;
					slides.forEach((slide, index) => {
						slide.style.left = newSlideWidth * index + "px";
					});
					track.style.transform = "translateX(-" + slides[currentIndex].style.left + ")";
				});

				setInterval(() => {
					const nextIndex = currentIndex < slides.length - 1 ? currentIndex + 1 : 0;
					const targetSlide = slides[nextIndex];
					moveToSlide(track, slides[currentIndex], targetSlide);
					currentIndex = nextIndex;
					updateIndicators(currentIndex);
				}, 5000);
			});
		</script>
	</body>
</html>