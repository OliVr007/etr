<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/teacher/teacher-grading.css" />
		<link rel="stylesheet" href="/css/mobile.css" />
		<title>Értékelések - Tanári felület</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<button class="hamburger-btn" aria-label="Menü">
						<div class="hamburger-icon">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</button>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/teacher">Áttekintés</a></li>
					<li><a href="/teacher/grading" class="active">Értékelések</a></li>
					<li><a href="/teacher/homework">Házi feladatok</a></li>
					<li><a href="/teacher/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container">
			<h1 class="grading-page-title">Értékelések kezelése</h1>

			<div class="grading-setup">
				<div class="setup-row">
					<div class="setup-group" style="flex: 2;">
						<label for="occupation">Foglalkozás</label>
						<select id="occupation" onchange="loadGradingData()">
							<option value="">-- Válasszon --</option>
							<% occupations.forEach(occ => { %>
							<option value="<%= occ.class_id %>-<%= occ.subject_id %>"><%= occ.label %></option>
							<% }); %>
						</select>
					</div>
					<div class="setup-group">
						<label for="gradeDate">Dátum</label>
						<input type="date" id="gradeDate" />
					</div>
					<div class="setup-group">
						<label for="gradeMode">Mód</label>
						<select id="gradeMode">
							<option value="felelet">Felelet</option>
							<option value="dolgozat">Dolgozat</option>
							<option value="házi">Házi feladat</option>
							<option value="projekt">Projekt</option>
						</select>
					</div>
					<div class="setup-group">
						<label for="gradeWeight">Súly</label>
						<select id="gradeWeight">
							<option value="1">100%</option>
							<option value="2">200%</option>
							<option value="3">300%</option>
						</select>
					</div>
				</div>
				<div class="setup-row" style="margin-top: 12px;">
					<div class="setup-group" style="flex: 1;">
						<label for="gradeTopic">Téma (opcionális)</label>
						<input type="text" id="gradeTopic" placeholder="pl. Mértani sorozatok" maxlength="200" />
					</div>
				</div>
			</div>

			<div class="grading-panel" id="gradingPanel" style="display: none;">
				<div class="grading-panel-header">
					<span class="panel-title" id="panelTitle">Értékelés rögzítése</span>
					<div class="panel-actions">
						<button class="btn btn-save" id="saveBtn" onclick="saveAllGrades()" disabled>Mentés</button>
						<button class="btn btn-cancel" onclick="cancelGrading()">Mégse</button>
					</div>
				</div>

				<div id="gradingContent">
					<div class="loading-spinner" id="loadingSpinner" style="display: none;">
						<div class="spinner"></div>
					</div>
					<div class="grading-table-wrapper" id="tableWrapper" style="display: none;">
						<table class="grading-table" id="gradingTable">
							<thead id="tableHead"></thead>
							<tbody id="tableBody"></tbody>
						</table>
					</div>
					<div class="grading-card-view" id="cardView" style="display: none;"></div>
					<div class="empty-state" id="emptyState">
						<div class="empty-state-icon">📝</div>
						<h3>Válasszon foglalkozást</h3>
						<p>Az értékelésekhez válasszon osztályt és tantárgyat.</p>
					</div>
				</div>
			</div>
		</main>

		<div class="modal-overlay" id="editModal">
			<div class="modal">
				<div class="modal-header">
					<h3>Értékelés szerkesztése</h3>
					<button class="modal-close" onclick="closeEditModal()">&times;</button>
				</div>
				<div class="modal-body">
					<input type="hidden" id="editGradeId" />
					<div class="form-group">
						<label>Diák</label>
						<input type="text" id="editStudentName" disabled />
					</div>
					<div class="form-group">
						<label>Osztályzat</label>
						<select id="editGradeValue">
							<option value="5">5 - Jeles</option>
							<option value="4">4 - Jó</option>
							<option value="3">3 - Közepes</option>
							<option value="2">2 - Elégséges</option>
							<option value="1">1 - Elégtelen</option>
						</select>
					</div>
					<div class="form-group">
						<label>Mód</label>
						<select id="editGradeType">
							<option value="felelet">Felelet</option>
							<option value="dolgozat">Dolgozat</option>
							<option value="házi">Házi feladat</option>
							<option value="projekt">Projekt</option>
						</select>
					</div>
					<div class="form-group">
						<label>Dátum</label>
						<input type="date" id="editGradeDate" />
					</div>
					<div class="form-group">
						<label>Súly</label>
						<select id="editGradeWeight">
							<option value="1">100%</option>
							<option value="2">200%</option>
							<option value="3">300%</option>
						</select>
					</div>
					<div class="form-group">
						<label>Téma</label>
						<input type="text" id="editGradeDescription" placeholder="opcionális" />
					</div>
				</div>
				<div class="modal-footer">
					<button class="btn btn-danger" onclick="deleteGradeFromModal()">Törlés</button>
					<button class="btn btn-secondary" onclick="closeEditModal()">Mégse</button>
					<button class="btn btn-primary" onclick="saveEditedGrade()">Mentés</button>
				</div>
			</div>
		</div>

		<!-- Törlés megerősítő -->
		<div class="modal-overlay" id="deleteConfirmModal">
			<div class="modal" style="max-width: 400px;">
				<div class="modal-header" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
					<h3>Értékelés törlése</h3>
					<button class="modal-close" onclick="closeDeleteModal()">&times;</button>
				</div>
				<div class="modal-body" style="text-align: center;">
					<p>Biztosan törölni szeretné ezt az értékelést?</p>
					<p style="color: #94a3b8; font-size: 0.9rem;">Ez a művelet nem vonható vissza.</p>
				</div>
				<div class="modal-footer" style="justify-content: center;">
					<button class="btn btn-secondary" onclick="closeDeleteModal()">Nem</button>
					<button class="btn btn-danger" onclick="confirmDelete()">Igen</button>
				</div>
			</div>
		</div>

		<!-- Mobil navigáció -->
		<div class="mobile-nav-overlay"></div>
		<div class="mobile-nav-drawer">
			<nav class="mobile-nav-links">
				<a href="/teacher"><span class="nav-icon">🏠</span> Áttekintés</a>
				<a href="/teacher/grading" class="active"><span class="nav-icon">📊</span> Értékelések</a>
				<a href="/teacher/homework"><span class="nav-icon">📝</span> Házi feladatok</a>
				<a href="/teacher/messages"><span class="nav-icon">✉️</span> Üzenetek</a>
			</nav>
			<div class="mobile-nav-logout">
				<a href="/logout">
					<img src="/icons/logouticon.svg" alt="Kijelentkezés" />
					Kijelentkezés
				</a>
			</div>
		</div>

		<script src="/js/mobile.js"></script>
		<script>
			let currentData = null;
			let currentClassId = null;
			let currentSubjectId = null;
			let pendingGrades = {};
			let deleteGradeId = null;

			document.getElementById("gradeDate").value = new Date().toISOString().split("T")[0];

			// === Adatok betöltése ===
			async function loadGradingData() {
				const sel = document.getElementById("occupation");
				if (!sel.value) {
					document.getElementById("gradingPanel").style.display = "none";
					return;
				}

				const [classId, subjectId] = sel.value.split("-").map(Number);
				currentClassId = classId;
				currentSubjectId = subjectId;

				document.getElementById("gradingPanel").style.display = "";
				document.getElementById("emptyState").style.display = "none";
				document.getElementById("tableWrapper").style.display = "none";
				document.getElementById("loadingSpinner").style.display = "flex";
				document.getElementById("panelTitle").textContent = sel.options[sel.selectedIndex].text;

				try {
					const resp = await fetch(`/api/teacher/grading/${classId}/${subjectId}`);
					const data = await resp.json();
					if (data.success) {
						currentData = data;
						pendingGrades = {};
						updateSaveButton();
						renderView();
					} else {
						showToast("Hiba az adatok betöltésekor", "error");
					}
				} catch (err) {
					showToast("Hálózati hiba", "error");
				}
				document.getElementById("loadingSpinner").style.display = "none";
			}

			// === Tábla renderelése ===
			function renderTable() {
				if (!currentData) return;
				const { students, gradesByStudent } = currentData;
				const thead = document.getElementById("tableHead");
				const tbody = document.getElementById("tableBody");
				const tableWrapper = document.getElementById("tableWrapper");

				if (students.length === 0) {
					document.getElementById("emptyState").style.display = "";
					document.getElementById("emptyState").innerHTML = '<div class="empty-state-icon">👥</div><h3>Nincsenek diákok</h3>';
					tableWrapper.style.display = "none";
					return;
				}

				thead.innerHTML = `<tr>
					<th class="col-index">#</th>
					<th class="col-name">Tanuló neve</th>
					<th>Eddigi jegyek</th>
					<th class="col-avg">Átlag</th>
					<th class="col-grade">Új jegy</th>
				</tr>`;

				let bodyHtml = "";
				students.forEach((student, idx) => {
					const sd = gradesByStudent[student.id];
					const avg = sd ? sd.average : 0;
					const avgClass = getAvgClass(avg);
					const grades = sd ? sd.grades : [];

					bodyHtml += `<tr>
						<td class="student-index">${idx + 1}.</td>
						<td class="student-name">${escapeHtml(student.name)}</td>
						<td style="text-align:center;">`;

					if (grades.length > 0) {
						bodyHtml += '<div class="existing-grades">';
						grades.forEach((g) => {
							const gClass = "g" + Math.round(g.value);
							const dateStr = new Date(g.date).toLocaleDateString("hu-HU");
							const typeLabel = { dolgozat: "Dolg.", felelet: "Fel.", házi: "Házi", projekt: "Proj." }[g.type] || g.type;
							bodyHtml += `<div class="grade-badge ${gClass}" onclick="openEditModal(${g.id}, '${escapeHtml(student.name)}', ${g.value}, '${g.type}', '${g.date.toString().split("T")[0]}', ${g.weight}, '${escapeHtml(g.description || "")}')">
								${g.value}
								<div class="grade-tooltip">${g.value} · ${typeLabel} · ${dateStr}${g.description ? " · " + escapeHtml(g.description) : ""}${g.weight > 1 ? " · " + g.weight + "x" : ""}</div>
							</div>`;
						});
						bodyHtml += "</div>";
					} else {
						bodyHtml += '<span style="color:#cbd5e1;">–</span>';
					}

					bodyHtml += `</td>
						<td class="avg-cell ${avgClass}">${avg > 0 ? avg : "–"}</td>
						<td class="grade-input-cell">
							<div class="grade-buttons">
								${[5, 4, 3, 2, 1].map((v) => {
									const selected = pendingGrades[student.id] == v ? `selected g${v}` : "";
									return `<button class="grade-btn ${selected}" onclick="selectGrade(${student.id}, ${v}, this)">${v}</button>`;
								}).join("")}
							</div>
						</td>
					</tr>`;
				});

				tbody.innerHTML = bodyHtml;
				tableWrapper.style.display = "";
				document.getElementById("emptyState").style.display = "none";
				document.getElementById("cardView").style.display = "none";
			}

			// === Kártya nézet renderelése (mobil) ===
			function renderCards() {
				if (!currentData) return;
				const { students, gradesByStudent } = currentData;
				const cardView = document.getElementById("cardView");
				const tableWrapper = document.getElementById("tableWrapper");

				if (students.length === 0) {
					document.getElementById("emptyState").style.display = "";
					document.getElementById("emptyState").innerHTML = '<div class="empty-state-icon">👥</div><h3>Nincsenek diákok</h3>';
					cardView.style.display = "none";
					return;
				}

				let html = "";
				students.forEach((student, idx) => {
					const sd = gradesByStudent[student.id];
					const avg = sd ? sd.average : 0;
					const avgClass = avg > 0 ? getAvgClass(avg) : "";
					const grades = sd ? sd.grades : [];
					const pending = pendingGrades[student.id];
					const hasPending = pending !== undefined;

					html += `<div class="student-grading-card${hasPending ? " has-pending" : ""}" id="card-${student.id}">
						<div class="student-card-header">
							<div class="student-card-name-row">
								<span class="student-card-index">${idx + 1}.</span>
								<span class="student-card-name">${escapeHtml(student.name)}</span>
							</div>
							<div class="student-card-avg ${avgClass}">${avg > 0 ? avg : "–"}</div>
						</div>`;

					if (grades.length > 0) {
						html += `<div class="student-card-existing-grades">`;
						grades.forEach((g) => {
							const gClass = "g" + Math.round(g.value);
							const dateStr = new Date(g.date).toLocaleDateString("hu-HU");
							const typeLabel = { dolgozat: "Dolg.", felelet: "Fel.", házi: "Házi", projekt: "Proj." }[g.type] || g.type;
							html += `<div class="grade-badge ${gClass}" onclick="openEditModal(${g.id}, '${escapeHtml(student.name)}', ${g.value}, '${g.type}', '${g.date.toString().split("T")[0]}', ${g.weight}, '${escapeHtml(g.description || "")}')">
								${g.value}
								<div class="grade-tooltip">${g.value} · ${typeLabel} · ${dateStr}${g.description ? " · " + escapeHtml(g.description) : ""}${g.weight > 1 ? " · " + g.weight + "x" : ""}</div>
							</div>`;
						});
						html += `</div>`;
					} else {
						html += `<div class="student-card-no-grades">Még nincs jegy</div>`;
					}

					html += `<div class="student-card-grade-row">
						<span class="student-card-grade-label">Új jegy</span>
						<div class="student-card-grade-buttons">
							${[5, 4, 3, 2, 1].map((v) => {
								const selected = pendingGrades[student.id] == v ? `selected g${v}` : "";
								return `<button class="grade-btn ${selected}" onclick="selectGradeCard(${student.id}, ${v}, this)">${v}</button>`;
							}).join("")}
						</div>
					</div>
				</div>`;
				});

				cardView.innerHTML = html;
				cardView.style.display = "flex";
				tableWrapper.style.display = "none";
				document.getElementById("emptyState").style.display = "none";
			}

			// === Jegy kiválasztása kártya nézetből ===
			function selectGradeCard(studentId, value, btn) {
				if (pendingGrades[studentId] == value) {
					delete pendingGrades[studentId];
					btn.classList.remove("selected", "g1", "g2", "g3", "g4", "g5");
				} else {
					pendingGrades[studentId] = value;
					const card = btn.closest(".student-grading-card");
					card.querySelectorAll(".grade-btn").forEach((b) => b.classList.remove("selected", "g1", "g2", "g3", "g4", "g5"));
					btn.classList.add("selected", "g" + value);
				}
				// Kártya stílus frissítése
				const card = btn.closest(".student-grading-card");
				if (pendingGrades[studentId]) {
					card.classList.add("has-pending");
				} else {
					card.classList.remove("has-pending");
				}
				updateSaveButton();
			}

			// === Mobil detektálás és render választás ===
			function isMobile() {
				return window.innerWidth <= 768;
			}

			function renderView() {
				if (isMobile()) {
					renderCards();
				} else {
					renderTable();
				}
			}

			// === Jegy kiválasztása ===
			function selectGrade(studentId, value, btn) {
				if (pendingGrades[studentId] == value) {
					delete pendingGrades[studentId];
					btn.classList.remove("selected", "g1", "g2", "g3", "g4", "g5");
				} else {
					pendingGrades[studentId] = value;
					const row = btn.closest("tr");
					row.querySelectorAll(".grade-btn").forEach((b) => b.classList.remove("selected", "g1", "g2", "g3", "g4", "g5"));
					btn.classList.add("selected", "g" + value);
				}
				updateSaveButton();
			}

			function updateSaveButton() {
				document.getElementById("saveBtn").disabled = Object.keys(pendingGrades).length === 0;
			}

			// === Mentés ===
			async function saveAllGrades() {
				const gradeDate = document.getElementById("gradeDate").value;
				const gradeMode = document.getElementById("gradeMode").value;
				const gradeWeight = parseInt(document.getElementById("gradeWeight").value);
				const gradeTopic = document.getElementById("gradeTopic").value.trim();

				if (!gradeDate) { showToast("Adjon meg dátumot!", "error"); return; }
				if (Object.keys(pendingGrades).length === 0) return;

				const grades = [];
				for (const [studentId, val] of Object.entries(pendingGrades)) {
					grades.push({
						student_id: parseInt(studentId),
						subject_id: currentSubjectId,
						grade_value: parseFloat(val),
						grade_type: gradeMode,
						description: gradeTopic || null,
						grade_date: gradeDate,
						is_final: false,
						weight: gradeWeight,
					});
				}

				document.getElementById("saveBtn").disabled = true;
				try {
					const resp = await fetch("/api/teacher/grading/save", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ grades }),
					});
					const data = await resp.json();
					if (data.success) {
						showToast(`${data.count} értékelés mentve!`, "success");
						pendingGrades = {};
						await loadGradingData();
					} else {
						showToast(data.error || "Hiba", "error");
					}
				} catch (err) {
					showToast("Hálózati hiba", "error");
				}
				document.getElementById("saveBtn").disabled = false;
			}

			function cancelGrading() {
				pendingGrades = {};
				updateSaveButton();
				if (currentData) renderView();
			}

			// === Szerkesztő modal ===
			function openEditModal(gradeId, studentName, value, type, date, weight, description) {
				document.getElementById("editGradeId").value = gradeId;
				document.getElementById("editStudentName").value = studentName;
				document.getElementById("editGradeValue").value = Math.round(value);
				document.getElementById("editGradeType").value = type;
				document.getElementById("editGradeDate").value = date;
				document.getElementById("editGradeWeight").value = weight || 1;
				document.getElementById("editGradeDescription").value = description || "";
				document.getElementById("editModal").classList.add("active");
			}

			function closeEditModal() { document.getElementById("editModal").classList.remove("active"); }

			async function saveEditedGrade() {
				const gradeId = document.getElementById("editGradeId").value;
				try {
					const resp = await fetch(`/api/teacher/grading/${gradeId}`, {
						method: "PUT",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							grade_value: document.getElementById("editGradeValue").value,
							grade_type: document.getElementById("editGradeType").value,
							grade_date: document.getElementById("editGradeDate").value,
							weight: document.getElementById("editGradeWeight").value,
							description: document.getElementById("editGradeDescription").value,
						}),
					});
					const result = await resp.json();
					if (result.success) {
						showToast("Módosítva!", "success");
						closeEditModal();
						await loadGradingData();
					} else showToast(result.error || "Hiba", "error");
				} catch (err) { showToast("Hálózati hiba", "error"); }
			}

			// === Törlés ===
			function deleteGradeFromModal() {
				deleteGradeId = document.getElementById("editGradeId").value;
				closeEditModal();
				document.getElementById("deleteConfirmModal").classList.add("active");
			}

			function closeDeleteModal() {
				document.getElementById("deleteConfirmModal").classList.remove("active");
				deleteGradeId = null;
			}

			async function confirmDelete() {
				if (!deleteGradeId) return;
				try {
					const resp = await fetch(`/api/teacher/grading/${deleteGradeId}`, { method: "DELETE" });
					const result = await resp.json();
					if (result.success) {
						showToast("Törölve!", "success");
						closeDeleteModal();
						await loadGradingData();
					} else showToast(result.error || "Hiba", "error");
				} catch (err) { showToast("Hálózati hiba", "error"); }
			}

			// === Segédfüggvények ===
			function getAvgClass(avg) {
				if (avg >= 4.5) return "avg-excellent";
				if (avg >= 3.5) return "avg-good";
				if (avg >= 2.5) return "avg-medium";
				if (avg >= 1.5) return "avg-poor";
				if (avg > 0) return "avg-fail";
				return "";
			}

			function escapeHtml(text) {
				if (!text) return "";
				const div = document.createElement("div");
				div.textContent = text;
				return div.innerHTML;
			}

			function showToast(message, type = "info") {
				document.querySelectorAll(".toast").forEach((t) => t.remove());
				const toast = document.createElement("div");
				toast.className = `toast toast-${type}`;
				toast.textContent = message;
				document.body.appendChild(toast);
				setTimeout(() => toast.remove(), 3200);
			}

			// Modal bezárás ESC-re és kívül kattintásra
			document.getElementById("editModal").addEventListener("click", function (e) { if (e.target === this) closeEditModal(); });
			document.getElementById("deleteConfirmModal").addEventListener("click", function (e) { if (e.target === this) closeDeleteModal(); });
			document.addEventListener("keydown", function (e) { if (e.key === "Escape") { closeEditModal(); closeDeleteModal(); } });

			// Nézet váltás ablak átméretezéskor
			let resizeTimer;
			window.addEventListener("resize", function () {
				clearTimeout(resizeTimer);
				resizeTimer = setTimeout(function () {
					if (currentData) renderView();
				}, 200);
			});
		</script>
	</body>
</html>