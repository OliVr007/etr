<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages-new.css" />
		<title>Új üzenet - Tanári felület</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main class="container messages-container">
			<section class="new-message-wrapper">
				<a href="/teacher/messages" class="back-link"> ← Vissza az üzenetekhez </a>
				<header class="new-message-header">
					<h2>Új üzenet írása</h2>
					<p>Küldj üzenetet diáknak, szülőnek vagy kollégának</p>
				</header>

				<form class="new-message-form" action="/api/teacher/messages/send" method="POST">
					<div class="form-group">
						<label for="recipient_type">Címzett típusa</label>
						<select id="recipient_type" name="recipient_type" required onchange="updateRecipientList()">
							<option value="">— Válassz típust —</option>
							<option value="student">Diák</option>
							<option value="parent">Szülő</option>
							<option value="teacher">Tanár</option>
							<option value="class">Osztály (összes diák)</option>
						</select>
					</div>

					<div class="form-group" id="class_selector_group" style="display: none;">
						<label for="class_selector">Válassz osztályt</label>
						<select id="class_selector" name="class_id" onchange="loadClassStudents()">
							<option value="">— Válassz osztályt —</option>
							<!-- Classes will be loaded dynamically -->
						</select>
					</div>

					<div class="form-group" id="recipient_group" style="display: none;">
						<label for="recipient">Címzett</label>
						<select id="recipient" name="recipient_id" required>
							<option value="">— Válassz címzettet —</option>
						</select>
					</div>

					<div class="form-group">
						<label for="subject">Tárgy</label>
						<input type="text" id="subject" name="subject" placeholder="Pl. Házi feladat megbeszélése" required />
					</div>

					<div class="form-group">
						<label for="content">Üzenet</label>
						<textarea id="content" name="content" rows="7" placeholder="Írd le részletesen az üzeneted…" required></textarea>
					</div>

					<div class="form-group">
						<label>
							<input type="checkbox" id="important" name="important" style="width: auto; margin-right: 8px;" />
							Fontos üzenet megjelölése
						</label>
					</div>

					<div class="form-actions">
						<button type="button" class="secondary-btn" onclick="window.location.href='/teacher/messages'">Mégse</button>
						<button type="submit" class="primary-btn">Üzenet küldése</button>
					</div>
				</form>
			</section>
		</main>

		<script>
			// Sample data - in production this would come from the server
			const teacherClasses = [
				{ id: 1, name: "9.A" },
				{ id: 2, name: "10.B" },
				{ id: 3, name: "11.C" }
			];

			const students = [
				{ id: 1, name: "Kovács János", class_id: 1 },
				{ id: 2, name: "Nagy Anna", class_id: 1 },
				{ id: 3, name: "Szabó Péter", class_id: 2 },
				{ id: 4, name: "Tóth Emma", class_id: 2 },
				{ id: 5, name: "Kiss Márton", class_id: 3 }
			];

			const teachers = [
				{ id: 1, name: "Dr. Molnár Katalin" },
				{ id: 2, name: "Varga László" },
				{ id: 3, name: "Horváth Erzsébet" }
			];

			function updateRecipientList() {
				const recipientType = document.getElementById('recipient_type').value;
				const recipientGroup = document.getElementById('recipient_group');
				const recipientSelect = document.getElementById('recipient');
				const classSelectorGroup = document.getElementById('class_selector_group');
				const classSelector = document.getElementById('class_selector');

				// Clear recipient select
				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';

				if (recipientType === 'class') {
					// Show class selector
					classSelectorGroup.style.display = 'flex';
					recipientGroup.style.display = 'none';
					
					// Load classes
					classSelector.innerHTML = '<option value="">— Válassz osztályt —</option>';
					teacherClasses.forEach(cls => {
						const option = document.createElement('option');
						option.value = cls.id;
						option.textContent = cls.name;
						classSelector.appendChild(option);
					});
					classSelector.required = true;
					recipientSelect.required = false;
				} else if (recipientType === 'student') {
					classSelectorGroup.style.display = 'flex';
					recipientGroup.style.display = 'flex';
					
					// Load classes
					classSelector.innerHTML = '<option value="">— Válassz osztályt —</option>';
					teacherClasses.forEach(cls => {
						const option = document.createElement('option');
						option.value = cls.id;
						option.textContent = cls.name;
						classSelector.appendChild(option);
					});
					classSelector.required = true;
					recipientSelect.required = true;
				} else if (recipientType === 'teacher') {
					classSelectorGroup.style.display = 'none';
					recipientGroup.style.display = 'flex';
					classSelector.required = false;
					recipientSelect.required = true;
					
					// Load teachers
					teachers.forEach(teacher => {
						const option = document.createElement('option');
						option.value = teacher.id;
						option.textContent = teacher.name;
						recipientSelect.appendChild(option);
					});
				} else if (recipientType === 'parent') {
					classSelectorGroup.style.display = 'flex';
					recipientGroup.style.display = 'flex';
					
					// Load classes
					classSelector.innerHTML = '<option value="">— Válassz osztályt —</option>';
					teacherClasses.forEach(cls => {
						const option = document.createElement('option');
						option.value = cls.id;
						option.textContent = cls.name;
						classSelector.appendChild(option);
					});
					classSelector.required = true;
					recipientSelect.required = true;
				} else {
					classSelectorGroup.style.display = 'none';
					recipientGroup.style.display = 'none';
					classSelector.required = false;
					recipientSelect.required = false;
				}
			}

			function loadClassStudents() {
				const classId = parseInt(document.getElementById('class_selector').value);
				const recipientType = document.getElementById('recipient_type').value;
				const recipientSelect = document.getElementById('recipient');
				
				if (!classId) {
					recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';
					return;
				}

				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';
				
				if (recipientType === 'student') {
					const classStudents = students.filter(s => s.class_id === classId);
					classStudents.forEach(student => {
						const option = document.createElement('option');
						option.value = student.id;
						option.textContent = student.name;
						recipientSelect.appendChild(option);
					});
				} else if (recipientType === 'parent') {
					const classStudents = students.filter(s => s.class_id === classId);
					classStudents.forEach(student => {
						const option = document.createElement('option');
						option.value = student.id;
						option.textContent = `${student.name} szülője`;
						recipientSelect.appendChild(option);
					});
				}
			}

			// Form submission
			document.querySelector('.new-message-form').addEventListener('submit', async (e) => {
				e.preventDefault();
				
				const formData = new FormData(e.target);
				const data = Object.fromEntries(formData);
				
				// For demonstration - in production this would send to the server
				console.log('Sending message:', data);
				alert('Üzenet elküldve! (Demo funkció)');
				window.location.href = '/teacher/messages';
			});
		</script>
	</body>
</html>
