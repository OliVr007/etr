<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages-new.css" />
		<title>Új üzenet - Tanári felület</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main>
			<section class="new-message-wrapper">
				<div class="message-form-header">
					<a href="/teacher/messages" class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
						</svg>
						Vissza
					</a>
					<header class="new-message-header">
						<h2>Új üzenet</h2>
						<p>Küldj üzenetet diáknak vagy kollégának</p>
					</header>
				</div>

				<div class="form-content">
					<form class="new-message-form" id="messageForm">
						<div class="form-group">
							<label for="recipient_type">Címzett típusa <span class="required-star">*</span></label>
							<select id="recipient_type" name="recipient_type" required>
								<option value="">— Válassz típust —</option>
								<option value="student">Diák</option>
								<option value="teacher">Tanár</option>
								<option value="class">Osztály (összes diák)</option>
							</select>
						</div>

						<div class="form-group" id="class_selector_group" style="display: none">
							<label for="class_selector">Osztály <span class="required-star">*</span></label>
							<select id="class_selector" name="class_id">
								<option value="">— Válassz osztályt —</option>
							</select>
						</div>

						<div class="form-group" id="recipient_group" style="display: none">
							<label for="recipient">Címzett <span class="required-star">*</span></label>
							<select id="recipient" name="receiver_id">
								<option value="">— Válassz címzettet —</option>
							</select>
						</div>

						<div class="form-group">
							<label for="subject">Tárgy <span class="required-star">*</span></label>
							<input type="text" id="subject" name="title" placeholder="Pl. Házi feladat" required />
						</div>

						<div class="form-group">
							<label for="content">Üzenet <span class="required-star">*</span></label>
							<textarea id="content" name="content" placeholder="Írd le az üzeneted..." required oninput="updateCharCounter()"></textarea>
							<div class="textarea-footer">
								<span class="char-counter" id="charCounter"><span id="charCount">0</span> / 10000</span>
								<button type="button" class="clear-btn" onclick="clearText()">Törlés</button>
							</div>
						</div>

						<div class="form-actions">
							<button type="button" class="secondary-btn" onclick="window.close()">Mégse</button>
							<button type="submit" class="primary-btn">Küldés</button>
						</div>
					</form>
				</div>
			</section>
		</main>

		<script>
			const MAX_CHARS = 10000;
			let allTeachers = [];
			let classStudents = {};

			async function loadInitialData() {
				try {
					const classesResp = await fetch("/api/teacher/classes");
					const classesData = await classesResp.json();
					const classes = classesData.classes || [];

					const classSelector = document.getElementById("class_selector");
					classes.forEach((cls) => {
						const option = document.createElement("option");
						option.value = cls.id;
						option.textContent = cls.name;
						classSelector.appendChild(option);
					});

					const teachersResp = await fetch("/api/teacher/messages/users");
					const teachersData = await teachersResp.json();
					allTeachers = (teachersData.users || []).filter((u) => u.role === "teacher");
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			async function loadClassStudents(classId) {
				if (classStudents[classId]) return classStudents[classId];

				try {
					const resp = await fetch(`/api/teacher/class/${classId}/students`);
					const data = await resp.json();
					classStudents[classId] = data.students || [];
					return classStudents[classId];
				} catch (error) {
					console.error("Hiba:", error);
					return [];
				}
			}

			function updateCharCounter() {
				const textarea = document.getElementById("content");
				const counter = document.getElementById("charCounter");
				const countSpan = document.getElementById("charCount");
				const length = textarea.value.length;

				countSpan.textContent = length;
				counter.classList.remove("warning", "danger");

				if (length > MAX_CHARS * 0.9) counter.classList.add("danger");
				else if (length > MAX_CHARS * 0.7) counter.classList.add("warning");
			}

			function clearText() {
				if (document.getElementById("content").value && confirm("Biztosan törlöd az üzenetet?")) {
					document.getElementById("content").value = "";
					updateCharCounter();
				}
			}

			document.getElementById("recipient_type").addEventListener("change", async function () {
				const type = this.value;
				const classSelectorGroup = document.getElementById("class_selector_group");
				const recipientGroup = document.getElementById("recipient_group");
				const classSelector = document.getElementById("class_selector");
				const recipientSelect = document.getElementById("recipient");

				classSelector.value = "";
				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';

				if (type === "student") {
					classSelectorGroup.style.display = "block";
					recipientGroup.style.display = "block";
				} else if (type === "class") {
					classSelectorGroup.style.display = "block";
					recipientGroup.style.display = "none";
				} else if (type === "teacher") {
					classSelectorGroup.style.display = "none";
					recipientGroup.style.display = "block";
					allTeachers.forEach((t) => {
						const option = document.createElement("option");
						option.value = t.id;
						option.textContent = `${t.last_name} ${t.first_name}`;
						recipientSelect.appendChild(option);
					});
				} else {
					classSelectorGroup.style.display = "none";
					recipientGroup.style.display = "none";
				}
			});

			document.getElementById("class_selector").addEventListener("change", async function () {
				const classId = this.value;
				const recipientType = document.getElementById("recipient_type").value;
				const recipientSelect = document.getElementById("recipient");

				if (!classId || recipientType === "class") return;

				recipientSelect.innerHTML = '<option value="">— Betöltés... —</option>';
				const students = await loadClassStudents(classId);
				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';

				students.forEach((s) => {
					const option = document.createElement("option");
					option.value = s.id;
					option.textContent = `${s.last_name} ${s.first_name}`;
					recipientSelect.appendChild(option);
				});
			});

			document.getElementById("messageForm").addEventListener("submit", async (e) => {
				e.preventDefault();

				const recipientType = document.getElementById("recipient_type").value;
				const classId = document.getElementById("class_selector").value;
				const recipientId = document.getElementById("recipient").value;
				const title = document.getElementById("subject").value;
				const content = document.getElementById("content").value;

				if (!title || !content) {
					alert("Minden mezőt ki kell tölteni!");
					return;
				}

				if (content.length > MAX_CHARS) {
					alert(`Maximum ${MAX_CHARS} karakter engedélyezett.`);
					return;
				}

				if (recipientType === "class") {
					if (!classId) {
						alert("Válassz osztályt!");
						return;
					}

					const students = await loadClassStudents(classId);
					if (students.length === 0) {
						alert("Nincsenek diákok ebben az osztályban!");
						return;
					}

					let successCount = 0;
					for (const student of students) {
						try {
							const resp = await fetch("/api/teacher/messages/send", {
								method: "POST",
								headers: { "Content-Type": "application/json" },
								body: JSON.stringify({ receiver_id: student.id, title, content }),
							});
							if (resp.ok) successCount++;
						} catch (e) {}
					}

					alert(`Üzenet elküldve ${successCount} diáknak!`);
					window.close();
				} else {
					if (!recipientId) {
						alert("Válassz címzettet!");
						return;
					}

					try {
						const resp = await fetch("/api/teacher/messages/send", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({ receiver_id: recipientId, title, content }),
						});

						if (resp.ok) {
							alert("Üzenet elküldve!");
							window.close();
						} else {
							const result = await resp.json();
							alert(result.error || "Hiba történt");
						}
					} catch (error) {
						alert("Hiba történt az üzenet küldésekor");
					}
				}
			});

			loadInitialData();
		</script>
	</body>
</html>
