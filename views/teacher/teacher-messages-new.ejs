<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages-new.css" />
		<title>Új üzenet - Tanári felület</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main class="container messages-container">
			<section class="new-message-wrapper">
				<a href="/teacher/messages" class="back-link"> ← Vissza az üzenetekhez </a>
				<header class="new-message-header">
					<h2>Új üzenet írása</h2>
					<p>Küldj üzenetet diáknak, szülőnek vagy kollégának</p>
				</header>

				<form class="new-message-form" id="messageForm">
					<div class="form-group">
						<label for="recipient_type">Címzett típusa</label>
						<select id="recipient_type" name="recipient_type" required>
							<option value="">— Válassz típust —</option>
							<option value="student">Diák</option>
							<option value="teacher">Tanár</option>
							<option value="class">Osztály (összes diák)</option>
						</select>
					</div>

					<div class="form-group" id="class_selector_group" style="display: none">
						<label for="class_selector">Válassz osztályt</label>
						<select id="class_selector" name="class_id">
							<option value="">— Válassz osztályt —</option>
						</select>
					</div>

					<div class="form-group" id="recipient_group" style="display: none">
						<label for="recipient">Címzett</label>
						<select id="recipient" name="receiver_id" required>
							<option value="">— Válassz címzettet —</option>
						</select>
					</div>

					<div class="form-group">
						<label for="subject">Tárgy</label>
						<input type="text" id="subject" name="title" placeholder="Pl. Házi feladat megbeszélése" required />
					</div>

					<div class="form-group">
						<label for="content">Üzenet</label>
						<textarea id="content" name="content" rows="7" placeholder="Írd le részletesen az üzeneted…" required></textarea>
					</div>

					<div class="form-actions">
						<button type="button" class="secondary-btn" onclick="window.close()">Mégse</button>
						<button type="submit" class="primary-btn">Üzenet küldése</button>
					</div>
				</form>
			</section>
		</main>

		<script>
			let allTeachers = [];
			let classStudents = {};

			async function loadInitialData() {
				try {
					// Osztályok betöltése
					const classesResp = await fetch("/api/teacher/classes");
					const classesData = await classesResp.json();
					const classes = classesData.classes || [];

					const classSelector = document.getElementById("class_selector");
					classes.forEach((cls) => {
						const option = document.createElement("option");
						option.value = cls.id;
						option.textContent = cls.name;
						classSelector.appendChild(option);
					});

					// Tanárok betöltése
					const teachersResp = await fetch("/api/teacher/messages/users");
					const teachersData = await teachersResp.json();
					allTeachers = (teachersData.users || []).filter((u) => u.role === "teacher");
				} catch (error) {
					console.error("Hiba az adatok betöltésekor:", error);
					alert("Hiba történt az adatok betöltésekor");
				}
			}

			async function loadClassStudents(classId) {
				if (classStudents[classId]) {
					return classStudents[classId];
				}

				try {
					const resp = await fetch(`/api/teacher/class/${classId}/students`);
					const data = await resp.json();
					classStudents[classId] = data.students || [];
					return classStudents[classId];
				} catch (error) {
					console.error("Hiba a diákok betöltésekor:", error);
					return [];
				}
			}

			document.getElementById("recipient_type").addEventListener("change", async function () {
				const recipientType = this.value;
				const recipientGroup = document.getElementById("recipient_group");
				const recipientSelect = document.getElementById("recipient");
				const classSelectorGroup = document.getElementById("class_selector_group");
				const classSelector = document.getElementById("class_selector");

				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';
				classSelector.value = "";

				if (recipientType === "class") {
					classSelectorGroup.style.display = "flex";
					recipientGroup.style.display = "none";
					classSelector.required = true;
					recipientSelect.required = false;
				} else if (recipientType === "student") {
					classSelectorGroup.style.display = "flex";
					recipientGroup.style.display = "flex";
					classSelector.required = true;
					recipientSelect.required = true;
				} else if (recipientType === "teacher") {
					classSelectorGroup.style.display = "none";
					recipientGroup.style.display = "flex";
					classSelector.required = false;
					recipientSelect.required = true;

					allTeachers.forEach((teacher) => {
						const option = document.createElement("option");
						option.value = teacher.id;
						option.textContent = `${teacher.last_name} ${teacher.first_name}`;
						recipientSelect.appendChild(option);
					});
				} else {
					classSelectorGroup.style.display = "none";
					recipientGroup.style.display = "none";
					classSelector.required = false;
					recipientSelect.required = false;
				}
			});

			document.getElementById("class_selector").addEventListener("change", async function () {
				const classId = this.value;
				const recipientType = document.getElementById("recipient_type").value;
				const recipientSelect = document.getElementById("recipient");

				if (!classId || recipientType === "class") return;

				recipientSelect.innerHTML = '<option value="">— Betöltés... —</option>';

				const students = await loadClassStudents(classId);
				recipientSelect.innerHTML = '<option value="">— Válassz címzettet —</option>';

				students.forEach((student) => {
					const option = document.createElement("option");
					option.value = student.id;
					option.textContent = `${student.last_name} ${student.first_name}`;
					recipientSelect.appendChild(option);
				});
			});

			document.getElementById("messageForm").addEventListener("submit", async (e) => {
				e.preventDefault();

				const recipientType = document.getElementById("recipient_type").value;
				const classId = document.getElementById("class_selector").value;
				const recipientId = document.getElementById("recipient").value;
				const title = document.getElementById("subject").value;
				const content = document.getElementById("content").value;

				if (!title || !content) {
					alert("Minden mezőt ki kell tölteni!");
					return;
				}

				if (recipientType === "class") {
					if (!classId) {
						alert("Válassz osztályt!");
						return;
					}

					const students = await loadClassStudents(classId);
					if (students.length === 0) {
						alert("Nincsenek diákok ebben az osztályban!");
						return;
					}

					try {
						let successCount = 0;
						for (const student of students) {
							const resp = await fetch("/api/teacher/messages/send", {
								method: "POST",
								headers: { "Content-Type": "application/json" },
								body: JSON.stringify({
									receiver_id: student.id,
									title: title,
									content: content,
								}),
							});

							if (resp.ok) successCount++;
						}

						alert(`Üzenet sikeresen elküldve ${successCount} diáknak!`);
						window.close();
					} catch (error) {
						console.error("Hiba az üzenetek küldésekor:", error);
						alert("Hiba történt az üzenetek küldésekor");
					}
				} else {
					if (!recipientId) {
						alert("Válassz címzettet!");
						return;
					}

					try {
						const resp = await fetch("/api/teacher/messages/send", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({
								receiver_id: recipientId,
								title: title,
								content: content,
							}),
						});

						const result = await resp.json();

						if (resp.ok) {
							alert("Üzenet sikeresen elküldve!");
							window.close();
						} else {
							alert(result.error || "Hiba történt az üzenet küldésekor");
						}
					} catch (error) {
						console.error("Hiba az üzenet küldésekor:", error);
						alert("Hiba történt az üzenet küldésekor");
					}
				}
			});

			loadInitialData();
		</script>
	</body>
</html>
