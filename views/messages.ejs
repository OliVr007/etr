<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/index.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/courses">Órarend</a></li>
					<li><a href="/tasks">Feladatok</a></li>
					<li><a href="/messages" class="active">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<h1>uzenet teszt</h1>

		<style>
			#messages {
				background-color: red;
				width: 75%;
				min-height: 300px;
			}

			.message {
				background-color: blue;
			}

			.message-title,
			.message-content {
				color: yellow;
			}
		</style>

		<div id="messages"></div>

		<script>
			async function loadMessages() {
				const resp = await fetch("/api/messages");
				const json = await resp.json();
				const messages = json["messages"];

				const messagesContainer = document.getElementById("messages");

				messagesContainer.innerHTML = "";

				messages.forEach((msg) => {
					const msgContainer = document.createElement("div");
					msgContainer.classList.add("message");

					const msgTitle = document.createElement("h1");
					msgTitle.classList.add("message-title");
					msgTitle.innerText = msg.title;

					const msgContent = document.createElement("p");
					msgContent.classList.add("message-content");
					msgContent.innerText = msg.content;

					msgContainer.appendChild(msgTitle);
					msgContainer.appendChild(msgContent);

					messagesContainer.appendChild(msgContainer);
				});
			}

			loadMessages();

			setInterval(loadMessages, 5000);
		</script>
	</body>
</html>
