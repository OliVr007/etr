<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/teacherui.css" />
		<title>Tanári Portál - Carousel Design</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/" class="active">Áttekintés</a></li>
					<li><a href="/orarend">Órarend</a></li>
					<li><a href="/osztalyok">Osztályok</a></li>
					<li><a href="/ertekelesek">Értékelések</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<main class="container">
			<section class="welcome-section">
				<h2>Üdvözöljük a Tanári Portálon!</h2>
				<p>Ma: 2023. október 12., szerda</p>
			</section>

			<div class="carousel-container">
				<button class="carousel-btn prev-btn" aria-label="Előző">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none">
						<path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>

				<div class="carousel-track">
					<!-- 1. kártya: Ma tartandó órák -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Ma tartandó órák</h3>
							<div class="card-badge">4 óra</div>
						</div>
						<div class="card-content">
							<div class="ora-elem">
								<div class="ora-info">
									<div class="ora-cim">9.A - Matematika</div>
									<div class="ora-idopont">8:00-8:45</div>
								</div>
								<div class="ora-terem">202-es terem</div>
							</div>
							<div class="ora-elem">
								<div class="ora-info">
									<div class="ora-cim">10.B - Matematika</div>
									<div class="ora-idopont">8:55-9:40</div>
								</div>
								<div class="ora-terem">305-ös terem</div>
							</div>
							<div class="ora-elem">
								<div class="ora-info">
									<div class="ora-cim">11.C - Fizika</div>
									<div class="ora-idopont">9:50-10:35</div>
								</div>
								<div class="ora-terem">Laboratórium</div>
							</div>
							<div class="ora-elem">
								<div class="ora-info">
									<div class="ora-cim">9.A - Fizika</div>
									<div class="ora-idopont">10:45-11:30</div>
								</div>
								<div class="ora-terem">202-es terem</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Összes óra megtekintése →</a>
						</div>
					</div>

					<!-- 2. kártya: Helyettesítések -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Helyettesítések</h3>
							<div class="card-badge">3 db</div>
						</div>
						<div class="card-content">
							<div class="helyettesites-elem">
								<div class="helyettesites-info">
									<div class="helyettesites-cim">Nagy Péter helyettesítése</div>
									<div class="helyettesites-datum">Okt. 12.</div>
								</div>
								<div class="helyettesites-osztaly">9.A - 3. óra</div>
							</div>
							<div class="helyettesites-elem">
								<div class="helyettesites-info">
									<div class="helyettesites-cim">Kiss Éva helyettesítése</div>
									<div class="helyettesites-datum">Okt. 13.</div>
								</div>
								<div class="helyettesites-osztaly">10.B - 5. óra</div>
							</div>
							<div class="helyettesites-elem">
								<div class="helyettesites-info">
									<div class="helyettesites-cim">Szabó Gábor helyettesítése</div>
									<div class="helyettesites-datum">Okt. 16.</div>
								</div>
								<div class="helyettesites-osztaly">11.C - 2. óra</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Összes helyettesítés →</a>
						</div>
					</div>

					<!-- 3. kártya: Be nem adott dolgozatok -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Be nem adott dolgozatok</h3>
							<div class="card-badge urgent">6 db</div>
						</div>
						<div class="card-content">
							<div class="dolgozat-elem">
								<div class="dolgozat-info">
									<div class="dolgozat-cim">Programozás beadandó</div>
									<div class="dolgozat-hatarido">Okt. 15.</div>
								</div>
								<div class="dolgozat-details">
									<span class="dolgozat-osztaly">10.B</span>
									<span class="dolgozat-hianyzo">3 diák</span>
								</div>
							</div>
							<div class="dolgozat-elem">
								<div class="dolgozat-info">
									<div class="dolgozat-cim">Matematika házi feladat</div>
									<div class="dolgozat-hatarido">Okt. 12.</div>
								</div>
								<div class="dolgozat-details">
									<span class="dolgozat-osztaly">9.A</span>
									<span class="dolgozat-hianyzo">1 diák</span>
								</div>
							</div>
							<div class="dolgozat-elem">
								<div class="dolgozat-info">
									<div class="dolgozat-cim">Fizika labor jegyzőkönyv</div>
									<div class="dolgozat-hatarido">Okt. 10.</div>
								</div>
								<div class="dolgozat-details">
									<span class="dolgozat-osztaly">11.C</span>
									<span class="dolgozat-hianyzo">2 diák</span>
								</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Összes dolgozat →</a>
						</div>
					</div>

					<!-- 4. kártya: Legutóbbi értékelések -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Legutóbbi értékelések</h3>
							<div class="card-badge">3 db</div>
						</div>
						<div class="card-content">
							<div class="ertekeles-elem">
								<div class="ertekeles-info">
									<div class="ertekeles-cim">9.A - Matematika ZH</div>
									<div class="ertekeles-datum">Okt. 12.</div>
								</div>
								<div class="ertekeles-atlag">Átlag: 72%</div>
							</div>
							<div class="ertekeles-elem">
								<div class="ertekeles-info">
									<div class="ertekeles-cim">10.B - Programozás beadandó</div>
									<div class="ertekeles-datum">Okt. 8.</div>
								</div>
								<div class="ertekeles-atlag">Átlag: 85%</div>
							</div>
							<div class="ertekeles-elem">
								<div class="ertekeles-info">
									<div class="ertekeles-cim">11.C - Fizika teszt</div>
									<div class="ertekeles-datum">Okt. 5.</div>
								</div>
								<div class="ertekeles-atlag">Átlag: 68%</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Összes értékelés →</a>
						</div>
					</div>

					<!-- 5. kártya: Figyelmeztetések -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Figyelmeztetések</h3>
							<div class="card-badge warning">3 db</div>
						</div>
						<div class="card-content">
							<div class="figyelmeztetes-elem">
								<div class="figyelmeztetes-info">
									<div class="figyelmeztetes-cim">Magas mulasztási arány</div>
									<div class="figyelmeztetes-datum">9.A</div>
								</div>
								<div class="figyelmeztetes-leiras">Kovács Béla - 15 óra</div>
							</div>
							<div class="figyelmeztetes-elem">
								<div class="figyelmeztetes-info">
									<div class="figyelmeztetes-cim">Rendszeresen késik</div>
									<div class="figyelmeztetes-datum">10.B</div>
								</div>
								<div class="figyelmeztetes-leiras">Szabó Eszter - 8 alkalom</div>
							</div>
							<div class="figyelmeztetes-elem">
								<div class="figyelmeztetes-info">
									<div class="figyelmeztetes-cim">Nem készül a házi feladatra</div>
									<div class="figyelmeztetes-datum">11.C</div>
								</div>
								<div class="figyelmeztetes-leiras">Tóth Gábor - 5 alkalom</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Összes figyelmeztetés →</a>
						</div>
					</div>

					<!-- 6. kártya: Következő értekezletek -->
					<div class="carousel-card">
						<div class="card-header">
							<h3>Következő értekezletek</h3>
							<div class="card-badge">3 db</div>
						</div>
						<div class="card-content">
							<div class="ertekezlet-elem">
								<div class="ertekezlet-info">
									<div class="ertekezlet-cim">Osztályfőnöki értekezlet</div>
									<div class="ertekezlet-datum">Okt. 15. 14:00</div>
								</div>
								<div class="ertekezlet-hely">Tanári szoba</div>
							</div>
							<div class="ertekezlet-elem">
								<div class="ertekezlet-info">
									<div class="ertekezlet-cim">Matematika szakértkezlet</div>
									<div class="ertekezlet-datum">Okt. 18. 15:30</div>
								</div>
								<div class="ertekezlet-hely">202-es terem</div>
							</div>
							<div class="ertekezlet-elem">
								<div class="ertekezlet-info">
									<div class="ertekezlet-cim">Tanesztély ülés</div>
									<div class="ertekezlet-datum">Okt. 22. 13:00</div>
								</div>
								<div class="ertekezlet-hely">Igazgatói szoba</div>
							</div>
						</div>
						<div class="card-footer">
							<a href="#" class="view-all">Naptár megtekintése →</a>
						</div>
					</div>
				</div>

				<button class="carousel-btn next-btn" aria-label="Következő">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none">
						<path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
			</div>
		</main>

		<script src="/js/teacherui.ejs"></script>
	</body>
</html>
