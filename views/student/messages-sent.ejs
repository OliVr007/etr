<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages" class="active">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main class="container messages-container">
			<div class="messages-header">
				<h1>Üzenetek</h1>
				<a href="/messages/new" target="_blank"><button class="new-message-btn">Új üzenet</button></a>
			</div>

			<div class="messages-tabs">
				<a href="/messages" class="tab">Beérkező</a>
				<a href="#" class="tab active">Elküldött</a>
			</div>

			<div class="messages-list" id="messages-list">
				<p style="text-align: center; color: #666; padding: 2rem">Betöltés...</p>
			</div>
		</main>

		<script>
			async function loadMessages() {
				try {
					const resp = await fetch("/api/messages/sent");
					const data = await resp.json();
					const messages = data.messages || [];

					const messagesContainer = document.getElementById("messages-list");
					messagesContainer.innerHTML = "";

					if (messages.length === 0) {
						messagesContainer.innerHTML = '<p style="text-align: center; color: #666; padding: 2rem;">Még nincs elküldött üzenet</p>';
						return;
					}

					messages.forEach((msg) => {
						const msgCard = document.createElement("div");
						msgCard.classList.add("message-card");

						const title = document.createElement("h2");
						title.textContent = msg.title;

						const receiver = document.createElement("p");
						receiver.innerHTML = `<strong>Címzett:</strong> ${msg.receiver.last_name} ${msg.receiver.first_name}`;
						receiver.style.fontSize = "0.9rem";
						receiver.style.color = "#666";

						const content = document.createElement("p");
						content.textContent = msg.content;

						const date = document.createElement("span");
						date.classList.add("date");
						date.textContent = new Date(msg.created_at).toLocaleDateString("hu-HU");

						msgCard.appendChild(title);
						msgCard.appendChild(receiver);
						msgCard.appendChild(content);
						msgCard.appendChild(date);

						messagesContainer.appendChild(msgCard);
					});
				} catch (error) {
					console.error("Hiba az üzenetek betöltésekor:", error);
					document.getElementById("messages-list").innerHTML = '<p style="text-align: center; color: #e63946; padding: 2rem;">Hiba történt az üzenetek betöltésekor</p>';
				}
			}

			loadMessages();
			setInterval(loadMessages, 5000);
		</script>
	</body>
</html>
