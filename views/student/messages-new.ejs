<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages-new.css" />
		<link rel="stylesheet" href="/css/mobile.css" />
		<title>Új üzenet</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main>
			<section class="new-message-wrapper">
				<div class="message-form-header">
					<a href="/messages" class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
						</svg>
						Vissza
					</a>
					<header class="new-message-header">
						<h2>Új üzenet</h2>
						<p>Küldj üzenetet diáknak vagy tanárnak</p>
					</header>
				</div>

				<div class="form-content">
					<form class="new-message-form" id="messageForm">
						<div class="form-group">
							<label for="recipient">Címzett <span class="required-star">*</span></label>
							<select id="recipient" name="receiver_id" required>
								<option value="">— Válassz címzettet —</option>
							</select>
						</div>

						<div class="form-group">
							<label for="subject">Tárgy <span class="required-star">*</span></label>
							<input type="text" id="subject" name="title" placeholder="Pl. ZH időpont" required />
						</div>

						<div class="form-group">
							<label for="content">Üzenet <span class="required-star">*</span></label>
							<textarea id="content" name="content" placeholder="Írd le az üzeneted..." required oninput="updateCharCounter()"></textarea>
							<div class="textarea-footer">
								<span class="char-counter" id="charCounter"><span id="charCount">0</span> / 5000</span>
								<button type="button" class="clear-btn" onclick="clearText()">Törlés</button>
							</div>
						</div>

						<div class="form-actions">
							<button type="button" class="secondary-btn" onclick="window.close()">Mégse</button>
							<button type="submit" class="primary-btn">Küldés</button>
						</div>
					</form>
				</div>
			</section>
		</main>

		<script>
			const MAX_CHARS = 5000;

			async function loadUsers() {
				try {
					const resp = await fetch("/api/messages/users");
					const data = await resp.json();
					const users = data.users || [];
					const select = document.getElementById("recipient");

					users
						.filter((user) => user.role === "teacher")
						.forEach((user) => {
							const option = document.createElement("option");
							option.value = user.id;
							option.textContent = `${user.last_name} ${user.first_name}`;
							select.appendChild(option);
						});
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt a címzettek betöltésekor");
				}
			}

			function updateCharCounter() {
				const textarea = document.getElementById("content");
				const counter = document.getElementById("charCounter");
				const countSpan = document.getElementById("charCount");
				const length = textarea.value.length;

				countSpan.textContent = length;
				counter.classList.remove("warning", "danger");

				if (length > MAX_CHARS * 0.9) counter.classList.add("danger");
				else if (length > MAX_CHARS * 0.7) counter.classList.add("warning");
			}

			function clearText() {
				if (document.getElementById("content").value && confirm("Biztosan törlöd az üzenetet?")) {
					document.getElementById("content").value = "";
					updateCharCounter();
				}
			}

			document.getElementById("messageForm").addEventListener("submit", async (e) => {
				e.preventDefault();

				const data = {
					receiver_id: document.getElementById("recipient").value,
					title: document.getElementById("subject").value,
					content: document.getElementById("content").value,
				};

				if (!data.receiver_id || !data.title || !data.content) {
					alert("Minden mezőt ki kell tölteni!");
					return;
				}

				if (data.content.length > MAX_CHARS) {
					alert(`Maximum ${MAX_CHARS} karakter engedélyezett.`);
					return;
				}

				try {
					const resp = await fetch("/api/messages/send", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(data),
					});

					if (resp.ok) {
						alert("Üzenet elküldve!");
						window.close();
					} else {
						const result = await resp.json();
						alert(result.error || "Hiba történt");
					}
				} catch (error) {
					alert("Hiba történt az üzenet küldésekor");
				}
			});

			loadUsers();
		</script>
	</body>
</html>
