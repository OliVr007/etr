<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/tasks/tasks.css" />
		<title>Házi feladatok - Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>
		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/courses">Órarend</a></li>
					<li><a href="/tasks" class="active">Házi feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main>
			<div class="container tasks-container">
				<h1>Házi feladatok</h1>
				<div class="task-list" id="task-list"></div>
			</div>
		</main>

		<script>
			document.addEventListener("DOMContentLoaded", loadHomeworks);

			async function loadHomeworks() {
				try {
					const resp = await fetch("/api/student/homeworks");
					const data = await resp.json();
					renderHomeworks(data.homeworks || []);
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			function renderHomeworks(homeworks) {
				const container = document.getElementById("task-list");

				if (homeworks.length === 0) {
					container.innerHTML = '<p class="empty-message">Nincs házi feladatod.</p>';
					return;
				}

				const statusText = {
					pending: "Folyamatban",
					submitted: "Ellenőrzés alatt...",
					accepted: "Kész",
				};

				const statusClass = {
					pending: "pending",
					submitted: "submitted",
					accepted: "completed",
				};

				let html = "";

				homeworks.forEach((hw) => {
					const dueDate = new Date(hw.due_date).toLocaleDateString("hu-HU");

					html += `
				<div class="task-card ${statusClass[hw.status]}">
					<h2>${hw.subject} – ${hw.title}</h2>
					<p>Határidő: ${dueDate}</p>
					<p>${hw.description}</p>
					<p class="teacher-name">Tanár: ${hw.teacher_name}</p>
					<p class="status-text">${statusText[hw.status]}</p>
					<div class="task-actions">
						${hw.status === "pending" ? `<button class="done-btn" onclick="submitHomework(${hw.id})" title="Beadás"><img src="/icons/check.svg" alt="Beadás" class="check-icon" /></button>` : ""}
						${hw.status === "accepted" ? `<button class="delete-btn" onclick="deleteHomework(${hw.id})" title="Törlés"><img src="/icons/delete.svg" alt="Törlés" class="trash-icon" /></button>` : ""}
					</div>
				</div>
			`;
				});

				container.innerHTML = html;
			}

			async function submitHomework(submissionId) {
				if (!confirm("Biztosan beadod a házi feladatot?")) return;

				try {
					const resp = await fetch(`/api/student/homework/submit/${submissionId}`, {
						method: "PUT",
					});

					if (resp.ok) {
						loadHomeworks();
					} else {
						alert("Hiba történt!");
					}
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			async function deleteHomework(submissionId) {
				if (!confirm("Biztosan törlöd a házi feladatot?")) return;

				try {
					const resp = await fetch(`/api/student/homework/${submissionId}`, {
						method: "DELETE",
					});

					if (resp.ok) {
						loadHomeworks();
					} else {
						alert("Hiba történt!");
					}
				} catch (error) {
					console.error("Hiba:", error);
				}
			}
		</script>
	</body>
</html>
