<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/tasks/tasks.css" />
		<link rel="stylesheet" href="/css/mobile.css" />
		<title>Házi feladatok - Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<button class="hamburger-btn" aria-label="Menü">
						<div class="hamburger-icon">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</button>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>
		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/tasks" class="active">Házi feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main>
			<div class="container tasks-container">
				<h1>Házi feladatok</h1>
				<div class="task-list" id="task-list"></div>
			</div>
		</main>

		<!-- Felugró ablak -->
		<div class="modal-overlay" id="descModal" onclick="closeModal()">
			<div class="modal-box" onclick="event.stopPropagation()">
				<div class="modal-header">
					<h2 id="modal-title"></h2>
					<button class="modal-close-btn" onclick="closeModal()">&times;</button>
				</div>
				<div class="modal-body">
					<p id="modal-description"></p>
				</div>
			</div>
		</div>

		<!-- Mobil navigáció -->
		<div class="mobile-nav-overlay"></div>
		<div class="mobile-nav-drawer">
			<nav class="mobile-nav-links">
				<a href="/"><span class="nav-icon">🏠</span> Áttekintés</a>
				<a href="/grades"><span class="nav-icon">📊</span> Értékelések</a>
				<a href="/tasks" class="active"><span class="nav-icon">📝</span> Házi feladatok</a>
				<a href="/messages"><span class="nav-icon">✉️</span> Üzenetek</a>
			</nav>
			<div class="mobile-nav-logout">
				<a href="/logout">
					<img src="/icons/logouticon.svg" alt="Kijelentkezés" />
					Kijelentkezés
				</a>
			</div>
		</div>

		<script src="/js/mobile.js"></script>
		<script>
			document.addEventListener("DOMContentLoaded", loadHomeworks);

			let homeworkData = [];

			function escapeHtml(text) {
				if (!text) return "";
				const div = document.createElement("div");
				div.textContent = text;
				return div.innerHTML;
			}

			function openModal(index) {
				const hw = homeworkData[index];
				document.getElementById("modal-title").textContent = hw.subject + " – " + hw.title;
				document.getElementById("modal-description").textContent = hw.description;
				document.getElementById("descModal").style.display = "flex";
				document.body.style.overflow = "hidden";
			}

			function closeModal() {
				document.getElementById("descModal").style.display = "none";
				document.body.style.overflow = "";
			}

			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") closeModal();
			});

			async function loadHomeworks() {
				try {
					const resp = await fetch("/api/student/homeworks");
					const data = await resp.json();
					renderHomeworks(data.homeworks || []);
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			function renderHomeworks(homeworks) {
				homeworkData = homeworks;
				const container = document.getElementById("task-list");

				if (homeworks.length === 0) {
					container.innerHTML = '<p class="empty-message">Nincs házi feladatod.</p>';
					return;
				}

				const statusText = {
					pending: "Folyamatban",
					submitted: "Ellenőrzés alatt...",
					accepted: "Kész",
				};

				const statusClass = {
					pending: "pending",
					submitted: "submitted",
					accepted: "completed",
				};

				let html = "";

				homeworks.forEach((hw, index) => {
					const dueDate = new Date(hw.due_date).toLocaleDateString("hu-HU");
					const needsModal = hw.description && hw.description.length > 150;
					const shortDesc = needsModal ? hw.description.substring(0, 150) + "..." : hw.description;

					html += `
						<div class="task-card ${statusClass[hw.status]}">
							<h2>${escapeHtml(hw.subject)} – ${escapeHtml(hw.title)}</h2>
							<p>Határidő: ${dueDate}</p>
							${hw.description ? `<p>${escapeHtml(shortDesc)}</p>` : ""}
							${needsModal ? `<button class="more-btn" onclick="openModal(${index})">Tovább →</button>` : ""}
							<p class="teacher-name">Tanár: ${escapeHtml(hw.teacher_name)}</p>
							<p class="status-text">${statusText[hw.status]}</p>
							<div class="task-actions">
								${hw.status === "pending" ? `<button class="done-btn" onclick="submitHomework(${hw.id})" title="Beadás"><img src="/icons/check.svg" alt="Beadás" class="check-icon" /></button>` : ""}
								${hw.status === "accepted" ? `<button class="delete-btn" onclick="deleteHomework(${hw.id})" title="Törlés"><img src="/icons/delete.svg" alt="Törlés" class="trash-icon" /></button>` : ""}
							</div>
						</div>
					`;
				});

				container.innerHTML = html;
			}

			async function submitHomework(submissionId) {
				if (!confirm("Biztosan beadod a házi feladatot?")) return;
				try {
					const resp = await fetch(`/api/student/homework/submit/${submissionId}`, { method: "PUT" });
					if (resp.ok) loadHomeworks();
					else alert("Hiba történt!");
				} catch (error) {
					console.error("Hiba:", error);
				}
			}

			async function deleteHomework(submissionId) {
				if (!confirm("Biztosan törlöd a házi feladatot?")) return;
				try {
					const resp = await fetch(`/api/student/homework/${submissionId}`, { method: "DELETE" });
					if (resp.ok) loadHomeworks();
					else alert("Hiba történt!");
				} catch (error) {
					console.error("Hiba:", error);
				}
			}
		</script>
	</body>
</html>
