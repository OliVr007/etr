<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/grades/grades.css" />
		<title>Értékelések</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades" class="active">Értékelések</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<div class="grades-table-container">
			<h2>Értékelések</h2>

			<% const months = ['Szeptember', 'Október', 'November', 'December', 'Január (I)', 'Félév', 'Január (II)', 'Február', 'Március', 'Április', 'Május', 'Június']; %>

			<table class="grades-table">
				<thead>
					<tr>
						<th>#</th>
						<th>Tantárgy</th>
						<% months.forEach(month => { %>
						<th><%= month %></th>
						<% }); %>
						<th>Évvége</th>
						<th>Átlag</th>
					</tr>
				</thead>

				<tbody>
					<% if (Object.keys(gradesBySubject).length === 0) { %>
					<tr>
						<td colspan="16" style="text-align: center; padding: 2rem">Még nincsenek értékelések</td>
					</tr>
					<% } else { %> <% let rowIndex = 1; function getMonthIndex(date) { const month = new Date(date).getMonth(); if (month === 0) return 4; if (month === 1) return 7; if (month === 2) return 8; if (month === 3) return 9; if (month === 4) return 10; if (month === 5) return 11; if (month === 8) return 0; if (month === 9) return 1; if (month === 10) return 2; if (month === 11) return 3; return -1; } function calculateAverage(grades) { if (!grades || grades.length === 0) return 0; const sum = grades.reduce((acc, g) => acc + parseFloat(g.grade_value), 0); return (sum / grades.length).toFixed(2); } function getGradeClass(gradeValue) { const num = parseFloat(gradeValue); if (num === 5) return 'g5'; if (num === 4) return 'g4'; if (num === 3) return 'g3'; if (num === 2) return 'g2'; if (num === 1) return 'g1'; return ''; } %> <% Object.keys(gradesBySubject).sort().forEach(subjectName => { %> <% const subjectGrades = gradesBySubject[subjectName]; const gradesByMonth =
					Array(12).fill(null).map(() => []); subjectGrades.forEach(grade => { const monthIdx = getMonthIndex(grade.grade_date); if (monthIdx >= 0) { gradesByMonth[monthIdx].push(grade); } }); const average = calculateAverage(subjectGrades); %>

					<tr>
						<td><%= rowIndex++ %></td>
						<td><%= subjectName %></td>

						<% gradesByMonth.forEach((monthGrades, idx) => { %>
						<td>
							<% if (monthGrades.length > 0) { %> <% monthGrades.forEach(grade => { %>
							<span class="<%= getGradeClass(grade.grade_value) %>" title="<%= grade.description %> (<%= grade.grade_type %>)"> <%= grade.grade_value %> </span>
							<% }); %> <% } %>
						</td>
						<% }); %>

						<td></td>
						<!-- Évvége -->
						<td><strong><%= average %></strong></td>
					</tr>
					<% }); %> <% } %>
				</tbody>
			</table>
		</div>
	</body>
</html>
