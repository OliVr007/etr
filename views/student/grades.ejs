<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/grades/grades.css" />
		<link rel="stylesheet" href="/css/mobile.css" />
		<title>Értékelések</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<button class="hamburger-btn" aria-label="Menü">
						<div class="hamburger-icon">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</button>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades" class="active">Értékelések</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<%
		const months = ['Szeptember', 'Október', 'November', 'December', 'Január', 'Február', 'Március', 'Április', 'Május', 'Június'];

		function getMonthIndex(date) {
			const month = new Date(date).getMonth();
			if (month === 0) return 4;  // Január → index 4
			if (month === 1) return 5;  // Február → index 5
			if (month === 2) return 6;  // Március → index 6
			if (month === 3) return 7;  // Április → index 7
			if (month === 4) return 8;  // Május → index 8
			if (month === 5) return 9;  // Június → index 9
			if (month === 8) return 0;  // Szeptember → index 0
			if (month === 9) return 1;  // Október → index 1
			if (month === 10) return 2; // November → index 2
			if (month === 11) return 3; // December → index 3
			return -1;
		}


		function calculateAverage(grades) {
			if (!grades || grades.length === 0) return null;
			const sum = grades.reduce((acc, g) => acc + parseFloat(g.grade_value), 0);
			return (sum / grades.length).toFixed(2);
		}

		function getGradeClass(gradeValue) {
			const num = parseFloat(gradeValue);
			if (num === 5) return 'g5';
			if (num === 4) return 'g4';
			if (num === 3) return 'g3';
			if (num === 2) return 'g2';
			if (num === 1) return 'g1';
			return '';
		}

		function getGradeTypeLabel(type) {
			const map = {
				dolgozat: 'Dolgozat',
				felelet: 'Felelet',
				h_zi: 'Gyakorlati feladat',
				projekt: 'Projekt'
			};
			return map[type] || type;
		}

		function getAvgClass(avg) {
			if (avg === null) return '';
			const num = parseFloat(avg);
			if (num >= 4.5) return 'avg-excellent';
			if (num >= 3.5) return 'avg-good';
			if (num >= 2.5) return 'avg-medium';
			if (num >= 1.5) return 'avg-poor';
			return 'avg-fail';
		}
		%>

		<div class="grades-table-container">
			<h2>Értékelések</h2>

			<div class="table-wrapper">
				<table class="grades-table">
					<thead>
						<tr>
							<th>#</th>
							<th>Tantárgy</th>
							<% months.forEach(month => { %>
							<th><%= month %></th>
							<% }); %>
							<th>Átlag</th>
						</tr>
					</thead>

					<tbody>
						<% if (Object.keys(gradesBySubject).length === 0) { %>
						<tr>
							<td colspan="13" style="text-align: center; padding: 2rem">Még nincsenek hozzárendelt tantárgyak</td>
						</tr>
						<% } else { %>
						<% let rowIndex = 1; %>
						<% Object.keys(gradesBySubject).forEach(subjectName => { %>
						<%
						const subjectGrades = gradesBySubject[subjectName];
						const gradesByMonth = Array(10).fill(null).map(() => []);

						subjectGrades.forEach(grade => {
							const monthIdx = getMonthIndex(grade.grade_date);
							if (monthIdx >= 0) {
								gradesByMonth[monthIdx].push(grade);
							}
						});

						const average = calculateAverage(subjectGrades);
						%>

						<tr class="<%= rowIndex === 1 ? 'first-row' : '' %>">
							<td><%= rowIndex++ %></td>
							<td><%= subjectName %></td>

							<% gradesByMonth.forEach((monthGrades, idx) => { %>
							<td>
								<% if (monthGrades.length > 0) { %>
									<% monthGrades.forEach(grade => { %>
									<span class="grade-cell <%= getGradeClass(grade.grade_value) %>">
										<%= grade.grade_value %>
										<div class="grade-tooltip">
											<div class="tooltip-date"><%= new Date(grade.grade_date).toLocaleDateString('hu-HU') %></div>
											<div class="tooltip-type"><%= getGradeTypeLabel(grade.grade_type) %></div>
											<% if (grade.description) { %>
											<div class="tooltip-desc">Téma: <%= grade.description %></div>
											<% } %>
											<div class="tooltip-weight">Súly: <%= (grade.weight || 1) * 100 %>%</div>
											<div class="tooltip-teacher"><%= grade.users_grades_teacher_idTousers.last_name %> <%= grade.users_grades_teacher_idTousers.first_name %></div>
										</div>
									</span>
									<% }); %>
								<% } %>
							</td>
							<% }); %>

							<td><strong><%= average !== null ? average : '-' %></strong></td>
						</tr>
						<% }); %>
						<% } %>
					</tbody>
				</table>
			</div>

			<div class="grades-card-view">
				<% if (Object.keys(gradesBySubject).length === 0) { %>
				<div class="grade-subject-card">
					<div class="grade-subject-header">
						<span class="grade-subject-name">Még nincsenek hozzárendelt tantárgyak</span>
					</div>
				</div>
				<% } else { %>
				<% Object.keys(gradesBySubject).forEach((subjectName, subjectIndex) => { %>
				<%
				const subjectGrades = gradesBySubject[subjectName];
				const gradesByMonthMobile = Array(10).fill(null).map(() => []);


				subjectGrades.forEach(grade => {
					const monthIdx = getMonthIndex(grade.grade_date);
					if (monthIdx >= 0) {
						gradesByMonthMobile[monthIdx].push(grade);
					}
				});

				const avgMobile = calculateAverage(subjectGrades);
				const avgClassMobile = getAvgClass(avgMobile);
				%>

				<div class="grade-subject-card" data-card-index="<%= subjectIndex %>">
					<div class="grade-subject-header" onclick="toggleGradeCard(this)">
						<span class="grade-subject-name"><%= subjectName %></span>
						<div class="grade-subject-avg">
							<span class="grade-avg-value <%= avgClassMobile %>"><%= avgMobile !== null ? avgMobile : '-' %></span>
							<svg class="grade-chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
							</svg>
						</div>
					</div>

					<div class="grade-subject-body">
						<div class="grade-subject-content">
							<% let hasAnyGrades = false; %>
							<% gradesByMonthMobile.forEach((monthGrades, mIdx) => { %>
								<% if (monthGrades.length > 0) { hasAnyGrades = true; %>
								<div class="grade-month-group">
									<div class="grade-month-label"><%= months[mIdx] %></div>
									<% monthGrades.forEach(grade => { %>
									<div class="grade-entry">
										<div class="grade-entry-info">
											<div class="grade-entry-type"><%= getGradeTypeLabel(grade.grade_type) %></div>
											<div class="grade-entry-details">
												<%= new Date(grade.grade_date).toLocaleDateString('hu-HU') %>
												· Súly: <%= (grade.weight || 1) * 100 %>%
												<% if (grade.description) { %> · <%= grade.description %><% } %>
											</div>
											<div class="grade-entry-details">
												<%= grade.users_grades_teacher_idTousers.last_name %> <%= grade.users_grades_teacher_idTousers.first_name %>
											</div>
										</div>
										<div class="grade-entry-value <%= getGradeClass(grade.grade_value) %>"><%= grade.grade_value %></div>
									</div>
									<% }); %>
								</div>
								<% } %>
							<% }); %>

							<% if (!hasAnyGrades) { %>
							<div class="grade-empty-card">Még nincs jegy ebből a tantárgyból</div>
							<% } %>

							<div class="grade-summary-row">
								<span class="grade-summary-label">Összes jegy: <%= subjectGrades.length %> db</span>
								<span class="grade-summary-value <%= avgClassMobile %>">Átlag: <%= avgMobile !== null ? avgMobile : '-' %></span>
							</div>
						</div>
					</div>
				</div>
				<% }); %>
				<% } %>
			</div>
		</div>

		<!-- Mobil navigáció -->
		<div class="mobile-nav-overlay"></div>
		<div class="mobile-nav-drawer">
			<nav class="mobile-nav-links">
				<a href="/"><span class="nav-icon">🏠</span> Áttekintés</a>
				<a href="/grades" class="active"><span class="nav-icon">📊</span> Értékelések</a>
				<a href="/tasks"><span class="nav-icon">📝</span> Házi feladatok</a>
				<a href="/messages"><span class="nav-icon">✉️</span> Üzenetek</a>
			</nav>
			<div class="mobile-nav-logout">
				<a href="/logout">
					<img src="/icons/logouticon.svg" alt="Kijelentkezés" />
					Kijelentkezés
				</a>
			</div>
		</div>

		<script src="/js/mobile.js"></script>
		<script>
			function toggleGradeCard(header) {
				const card = header.closest('.grade-subject-card');
				card.classList.toggle('open');
			}

			const floatingTooltip = document.createElement('div');
			floatingTooltip.id = 'floating-grade-tooltip';
			floatingTooltip.style.cssText = [
				'display:none',
				'position:fixed',
				'background:white',
				'border-left:4px solid #1282a2',
				'padding:12px 16px',
				'border-radius:8px',
				'box-shadow:0 4px 20px rgba(0,0,0,0.15)',
				'white-space:nowrap',
				'z-index:99999',
				'pointer-events:none',
				'min-width:180px',
				'text-align:left',
				'font-size:0.875rem',
				'font-family:Segoe UI,Tahoma,Geneva,Verdana,sans-serif',
				'transition:opacity 0.18s ease, transform 0.18s ease',
				'opacity:0',
				'transform:translateY(4px)'
			].join(';');
			document.body.appendChild(floatingTooltip);

			document.querySelectorAll('.grade-cell').forEach(cell => {
				const inner = cell.querySelector('.grade-tooltip');
				if (!inner) return;

				cell.addEventListener('mouseenter', () => {
					floatingTooltip.innerHTML = inner.innerHTML;
					floatingTooltip.style.display = 'block';

					const rect = cell.getBoundingClientRect();
					const ttW = floatingTooltip.offsetWidth;
					const ttH = floatingTooltip.offsetHeight;

					const row = cell.closest('tr');
					const tbody = row.closest('tbody');
					const isFirstRow = tbody && tbody.rows[0] === row;

					let left = rect.left + rect.width / 2 - ttW / 2;
					let top = isFirstRow ? rect.top - ttH - 10 : rect.bottom + 10;

					if (left + ttW > window.innerWidth - 8) left = window.innerWidth - ttW - 8;
					if (left < 8) left = 8;

					floatingTooltip.style.left = left + 'px';
					floatingTooltip.style.top = top + 'px';
					
					floatingTooltip.style.transform = isFirstRow ? 'translateY(-4px)' : 'translateY(4px)';
					floatingTooltip.style.opacity = '0';
					requestAnimationFrame(() => {
						floatingTooltip.style.opacity = '1';
						floatingTooltip.style.transform = 'translateY(0)';
					});
				});

				cell.addEventListener('mouseleave', () => {
					floatingTooltip.style.opacity = '0';
					setTimeout(() => { floatingTooltip.style.display = 'none'; }, 180);
				});
			});
		</script>
	</body>
</html>
