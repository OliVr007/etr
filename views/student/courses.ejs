<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/courses/courses.css" />
		<title>Órarend</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/courses" class="active">Órarend</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>

		<div class="timetable-container">
			<% if (className) { %>
			<h1 style="text-align: center; margin-bottom: 10px"><%= className %> osztály órarendje</h1>
			<% } %>
			<p id="current-date" style="text-align: center; margin-bottom: 35px; color: #666"></p>

			<% if (timetable.length === 0) { %>
			<div style="text-align: center; padding: 3rem; color: #666">
				<p>Még nincs órarend beállítva ehhez az osztályhoz.</p>
			</div>
			<% } else { %> <% const days = ['Hétfő', 'Kedd', 'Szerda', 'Csütörtök', 'Péntek']; const schedule = {}; for (let day = 1; day <= 5; day++) { schedule[day] = {}; } timetable.forEach(item => { if (!schedule[item.day_of_week]) { schedule[item.day_of_week] = {}; } schedule[item.day_of_week][item.lesson_number] = item; }); let maxLessons = 0; Object.values(schedule).forEach(day => { const lessons = Object.keys(day).map(Number); if (lessons.length > 0) { maxLessons = Math.max(maxLessons, Math.max(...lessons)); } }); function getLessonTime(lessonNumber) { const startHour = 7 + lessonNumber; const startMinute = (lessonNumber - 1) * 5; const endMinute = startMinute + 45; const startTime = String(startHour) + ':' + String(startMinute).padStart(2, '0'); const endTime = String(startHour) + ':' + String(endMinute).padStart(2, '0'); return startTime + '–' + endTime; } %>

			<div class="timetable">
				<% days.forEach(day => { %>
				<div class="timetable-header"><%= day %></div>
				<% }); %> <% for (let lesson = 1; lesson <= maxLessons; lesson++) { %> <% for (let day = 1; day <= 5; day++) { %>
				<div>
					<% if (schedule[day] && schedule[day][lesson]) { %> <% const item = schedule[day][lesson]; %>
					<div class="lesson">
						<strong><%= item.subjects.subject_name %></strong>
						<span><%= item.room_number %> • <%= getLessonTime(lesson) %></span>
					</div>
					<% } else { %>
					<div class="lesson empty">
						<span style="color: #ccc">—</span>
					</div>
					<% } %>
				</div>
				<% } %> <% } %>
			</div>
			<% } %>
		</div>
		<script>
			const dateElem = document.getElementById("current-date");
			const now = new Date();
			const options = { year: "numeric", month: "long", day: "numeric", weekday: "long" };
			dateElem.textContent = now.toLocaleDateString("hu-HU", options);
		</script>
	</body>
</html>
