<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages" class="active">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main class="container messages-container">
			<div class="messages-header">
				<h1>Üzenetek</h1>
				<a href="/messages/new" target="_blank"><button class="new-message-btn">Új üzenet</button></a>
			</div>

			<div class="messages-tabs">
				<a href="#" class="tab active">Beérkező</a>
				<a href="/messages/sent" class="tab">Elküldött</a>
			</div>

			<div class="messages-list" id="messages-list">
				<p style="text-align: center; color: #666; padding: 2rem">Betöltés...</p>
			</div>
		</main>

		<script>
			function escapeHtml(text) {
				const div = document.createElement("div");
				div.textContent = text;
				return div.innerHTML;
			}

			function toggleExpand(contentId, button, event) {
				event.stopPropagation();
				const content = document.getElementById(contentId);
				const isExpanded = content.classList.contains("expanded");

				if (isExpanded) {
					content.classList.remove("expanded");
					content.classList.add("collapsed");
					button.classList.remove("expanded");
					button.querySelector("span").textContent = "Továbbiak";
				} else {
					content.classList.remove("collapsed");
					content.classList.add("expanded");
					button.classList.add("expanded");
					button.querySelector("span").textContent = "Kevesebb";
				}
			}

			async function loadMessages() {
				try {
					const resp = await fetch("/api/messages/received");
					const data = await resp.json();
					const messages = data.messages || [];

					const messagesContainer = document.getElementById("messages-list");
					messagesContainer.innerHTML = "";

					if (messages.length === 0) {
						messagesContainer.innerHTML = `
							<div class="messages-empty">
								<div class="messages-empty-icon">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
										<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
									</svg>
								</div>
								<h3>Nincs üzenet</h3>
								<p>Még nem érkezett beérkező üzenet</p>
							</div>
						`;
						return;
					}

					messages.forEach((msg) => {
						const msgCard = document.createElement("div");
						msgCard.classList.add("message-card");

						const senderName = `${msg.sender.last_name} ${msg.sender.first_name}`;
						const initials = msg.sender.last_name.charAt(0) + msg.sender.first_name.charAt(0);

						const date = new Date(msg.created_at);
						const formattedDate = date.toLocaleDateString("hu-HU", {
							year: "numeric",
							month: "short",
							day: "numeric",
						});

						const isLong = msg.content.length > 150;
						const contentId = `content-${msg.id}`;

						msgCard.innerHTML = `
							<div class="message-card-header">
								<div class="message-card-header-left">
									<h2>${escapeHtml(msg.title)}</h2>
									<div class="message-sender">
										<div class="message-sender-avatar">${initials}</div>
										<div>
											<div class="message-sender-name">${escapeHtml(senderName)}</div>
											<div class="message-sender-label">Feladó</div>
										</div>
									</div>
								</div>
								<span class="message-date">${formattedDate}</span>
							</div>
							<div class="message-card-body">
								<div class="message-content ${isLong ? "collapsed" : ""}" id="${contentId}">
									<p>${escapeHtml(msg.content)}</p>
								</div>
								${
									isLong
										? `
									<button class="message-expand-btn" onclick="toggleExpand('${contentId}', this, event)">
										<span>Továbbiak</span>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="6 9 12 15 18 9"></polyline>
										</svg>
									</button>
								`
										: ""
								}
							</div>
						`;

						messagesContainer.appendChild(msgCard);
					});
				} catch (error) {
					console.error("Hiba az üzenetek betöltésekor:", error);
					document.getElementById("messages-list").innerHTML = '<p style="text-align: center; color: #e63946; padding: 2rem;">Hiba történt az üzenetek betöltésekor</p>';
				}
			}

			loadMessages();
			setInterval(loadMessages, 5000);
		</script>
	</body>
</html>
