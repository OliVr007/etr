<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/messages/messages.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<span>Kijelentkezés</span>
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/grades">Értékelések</a></li>
					<li><a href="/courses">Órarend</a></li>
					<li><a href="/tasks">Házi feladatok</a></li>
					<li><a href="/messages" class="active">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main class="container messages-container">
			<div class="messages-header">
				<h1>Üzenetek</h1>
				<a href="/messages/new" target="_blank"><button class="new-message-btn">Új üzenet</button></a>
			</div>

			<div class="messages-tabs">
				<a href="#" class="tab active">Beérkező</a>
				<a href="/messages/sent" class="tab">Elküldött</a>
			</div>

			<div class="messages-list">
				<div class="message-card">
					<h2>Tanár üzenete</h2>
					<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla facilisi.</p>
					<span class="date">2025.02.12</span>
				</div>

				<div class="message-card">
					<h2>Rendszerüzenet</h2>
					<p>Holnap karbantartás miatt az oldal 2 órára nem lesz elérhető.</p>
					<span class="date">2025.02.10</span>
				</div>
			</div>
		</main>

		<script>
			async function loadMessages() {
				const resp = await fetch("/api/messages");
				const json = await resp.json();
				const messages = json["messages"];

				const messagesContainer = document.getElementById("messages");

				messagesContainer.innerHTML = "";

				messages.forEach((msg) => {
					const msgContainer = document.createElement("div");
					msgContainer.classList.add("message");

					const msgTitle = document.createElement("h1");
					msgTitle.classList.add("message-title");
					msgTitle.innerText = msg.title;

					const msgContent = document.createElement("p");
					msgContent.classList.add("message-content");
					msgContent.innerText = msg.content;

					msgContainer.appendChild(msgTitle);
					msgContainer.appendChild(msgContent);

					messagesContainer.appendChild(msgContainer);
				});
			}

			loadMessages();

			setInterval(loadMessages, 5000);
		</script>
	</body>
</html>
