<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/tasks/tasks.css" />
		<title>Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>
		<nav>
			<div class="container">
				<ul class="nav-menu">
					<li><a href="/">Áttekintés</a></li>
					<li><a href="/courses">Órarend</a></li>
					<li><a href="/tasks" class="active">Feladatok</a></li>
					<li><a href="/messages">Üzenetek</a></li>
				</ul>
			</div>
		</nav>
		<main>
			<div class="container tasks-container">
				<h1>Házi feladatok</h1>

				<div class="task-list">
					<div class="task-card pending">
						<h2>Matematika – Másodfokú egyenletek</h2>
						<p>Határidő: 2025.02.12</p>
						<p>Oldd meg a feladatlap 1–8. példáit.</p>
						<p class="status-text">Folyamatban</p>
						<div class="task-actions">
							<button class="done-btn" type="button" title="Kész">
								<img src="/icons/check.svg" alt="Kész!" class="check-icon" />
							</button>
							<button class="delete-btn" type="button" title="Törlés">
								<img src="/icons/delete.svg" alt="Törlés" class="trash-icon" />
							</button>
						</div>
					</div>

					<div class="task-card pending">
						<h2>Fizika – Newton törvényei</h2>
						<p>Határidő: 2025.02.15</p>
						<p>Készíts jegyzetet a tankönyv 56–60. oldaláról.</p>
						<p class="status-text">Folyamatban</p>
						<div class="task-actions">
							<button class="done-btn" type="button" title="Kész">
								<img src="/icons/check.svg" alt="Kész" class="check-icon" />
							</button>
							<button class="delete-btn" type="button" title="Törlés">
								<img src="/icons/delete.svg" alt="Törlés" class="trash-icon" />
							</button>
						</div>
					</div>

					<div class="task-card completed">
						<h2>Irodalom – Arany János élete</h2>
						<p>Leadva</p>
						<p class="status-text">Leadva</p>
					</div>
				</div>
			</div>
		</main>
		<script>
			// Kész / Kivétel a készből – pipa gomb
			const doneButtons = document.querySelectorAll(".task-card .done-btn");

			doneButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const card = btn.closest(".task-card");
					if (!card) return;

					const status = card.querySelector(".status-text");

					// Ha már kész → visszaváltás pending-re
					if (card.classList.contains("completed")) {
						card.classList.remove("completed");
						card.classList.add("pending");
						if (status) status.textContent = "Folyamatban";
						btn.classList.remove("active");
						return;
					}

					// Ha pending → kész állapot beállítása
					card.classList.add("completed");
					card.classList.remove("pending");
					if (status) status.textContent = "Leadva";
					btn.classList.add("active");
				});
			});

			// Törlés – kuka gomb megerősítéssel
			const deleteButtons = document.querySelectorAll(".task-card .delete-btn");

			deleteButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const card = btn.closest(".task-card");
					if (!card) return;

					if (confirm("Biztosan törlöd a feladatot?")) {
						card.remove();
					}
				});
			});
		</script>
	</body>
</html>
