<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/admin/admin-index.css" />
    <title>Admin - Felhasználók</title>
</head>
<body>
    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo-section">
                    <img src="/icons/icon-128.webp" alt="Iskola logo" />
                </div>
                <div class="user-info">
                    <a href="/logout" class="logout-btn">
                        <span>Kijelentkezés</span>
                        <img src="/icons/logouticon.svg" alt="Kijelentkezés" />
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="container">
        <section class="stats-section">
            <h2>Statisztikák</h2>
            <div class="stats-grid">
                <div class="stat-card" onclick="location.href='/admin'">
                    <div class="stat-icon">👥</div>
                    <div class="stat-info"><h3><%= stats.totalUsers %></h3><p>Felhasználók</p></div>
                </div>
                <div class="stat-card" onclick="location.href='/admin/classes'">
                    <div class="stat-icon">🏫</div>
                    <div class="stat-info"><h3><%= stats.totalClasses %></h3><p>Osztályok</p></div>
                </div>
                <div class="stat-card" onclick="location.href='/admin/subjects'">
                    <div class="stat-icon">📚</div>
                    <div class="stat-info"><h3><%= stats.totalSubjects %></h3><p>Tantárgyak</p></div>
                </div>
                <div class="stat-card" onclick="location.href='/admin/assignments'">
                    <div class="stat-icon">🔗</div>
                    <div class="stat-info"><h3><%= stats.totalAssignments %></h3><p>Hozzárendelések</p></div>
                </div>
            </div>
        </section>

        <div class="tab-nav">
            <a href="/admin" class="tab-btn active">👥 Felhasználók</a>
            <a href="/admin/classes" class="tab-btn">🏫 Osztályok</a>
            <a href="/admin/subjects" class="tab-btn">📚 Tantárgyak</a>
            <a href="/admin/assignments" class="tab-btn">🔗 Hozzárendelések</a>
        </div>

        <div class="tab-content active" id="tab-users">
            <section class="content-section">
                <div class="section-header">
                    <h2>Felhasználó kezelés</h2>
                    <button class="btn-primary" onclick="openAddUserModal()"><span>➕</span> Új felhasználó</button>
                </div>
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ID</th><th>Felhasználónév</th><th>Név</th>
                                <th>Email</th><th>Szerepkör</th><th>Műveletek</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user => { %>
                            <tr>
                                <td><%= user.id %></td>
                                <td><%= user.username %></td>
                                <td><%= user.last_name %> <%= user.first_name %></td>
                                <td><%= user.email || '-' %></td>
                                <td>
                                    <span class="role-badge role-<%= user.role %>">
                                        <% if (user.role === 'student') { %> 🎓 Diák
                                        <% } else if (user.role === 'teacher') { %> 👨‍🏫 Tanár
                                        <% } else if (user.role === 'admin') { %> ⚙️ Admin
                                        <% } %>
                                    </span>
                                </td>
                                <td class="action-buttons">
                                    <button class="btn-edit" onclick="openEditUserModal(<%= user.id %>)">✏️</button>
                                    <button class="btn-delete" onclick="deleteUser(<%= user.id %>, '<%= user.username %>')">🗑️</button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>

    <!-- Add User Modal -->
    <div id="addUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Új felhasználó hozzáadása</h3>
                <button class="close-btn" onclick="closeModal('addUserModal')">&times;</button>
            </div>
            <form onsubmit="addUser(event)">
                <div class="form-group">
                    <label>Felhasználónév *</label>
                    <input type="text" id="add_username" name="username" required />
                </div>
                <div class="form-group">
                    <label>Jelszó *</label>
                    <input type="password" id="add_password" name="password" required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Keresztnév *</label>
                        <input type="text" id="add_first_name" name="first_name" required />
                    </div>
                    <div class="form-group">
                        <label>Vezetéknév *</label>
                        <input type="text" id="add_last_name" name="last_name" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="add_email" name="email" required />
                </div>
                <div class="form-group">
                    <label>Szerepkör *</label>
                    <select id="add_role" name="role" required onchange="toggleClassSelector('add')">
                        <option value="">Válassz...</option>
                        <option value="student">Diák</option>
                        <option value="teacher">Tanár</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="form-group" id="add_class_group" style="display: none;">
                    <label>Osztály *</label>
                    <select id="add_class" name="class_id">
                        <option value="">Válassz osztályt...</option>
                        <% classes.forEach(cls => { %>
                        <option value="<%= cls.id %>"><%= cls.class_name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-secondary" onclick="closeModal('addUserModal')">Mégse</button>
                    <button type="submit" class="btn-primary">Létrehozás</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div id="editUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Felhasználó szerkesztése</h3>
                <button class="close-btn" onclick="closeModal('editUserModal')">&times;</button>
            </div>
            <form onsubmit="updateUser(event)">
                <input type="hidden" id="edit_user_id" />
                <div class="form-group">
                    <label>Felhasználónév *</label>
                    <input type="text" id="edit_username" name="username" required />
                </div>
                <div class="form-group">
                    <label>Új jelszó (üresen hagyva nem változik)</label>
                    <input type="password" id="edit_password" name="password" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Keresztnév *</label>
                        <input type="text" id="edit_first_name" name="first_name" required />
                    </div>
                    <div class="form-group">
                        <label>Vezetéknév *</label>
                        <input type="text" id="edit_last_name" name="last_name" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="edit_email" name="email" required />
                </div>
                <div class="form-group">
                    <label>Szerepkör *</label>
                    <select id="edit_role" name="role" required onchange="toggleClassSelector('edit')">
                        <option value="student">Diák</option>
                        <option value="teacher">Tanár</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="form-group" id="edit_class_group" style="display: none;">
                    <label>Osztály *</label>
                    <select id="edit_class" name="class_id">
                        <option value="">Válassz osztályt...</option>
                        <% classes.forEach(cls => { %>
                        <option value="<%= cls.id %>"><%= cls.class_name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-secondary" onclick="closeModal('editUserModal')">Mégse</button>
                    <button type="submit" class="btn-primary">Mentés</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function closeModal(modalId) {
            document.getElementById(modalId).style.display = "none";
            const form = document.getElementById(modalId).querySelector('form');
            if (form) form.reset();
            document.getElementById("add_class_group").style.display = "none";
            document.getElementById("edit_class_group").style.display = "none";
        }
        window.onclick = (e) => {
            document.querySelectorAll('.modal').forEach(m => { if (e.target === m) closeModal(m.id); });
        };
        function toggleClassSelector(mode) {
            const val = document.getElementById(mode + '_role').value;
            const group = document.getElementById(mode + '_class_group');
            const sel = document.getElementById(mode + '_class');
            if (val === 'student') { group.style.display = 'flex'; sel.required = true; }
            else { group.style.display = 'none'; sel.required = false; sel.value = ''; }
        }
        function openAddUserModal() { document.getElementById("addUserModal").style.display = "flex"; }
        async function openEditUserModal(userId) {
            const response = await fetch('/api/admin/users/' + userId);
            const user = await response.json();
            if (!response.ok) return alert("Hiba történt a felhasználó betöltésekor");
            document.getElementById("edit_user_id").value = user.id;
            document.getElementById("edit_username").value = user.username;
            document.getElementById("edit_first_name").value = user.first_name;
            document.getElementById("edit_last_name").value = user.last_name;
            document.getElementById("edit_email").value = user.email || "";
            document.getElementById("edit_role").value = user.role;
            document.getElementById("edit_password").value = "";
            if (user.role === 'student') {
                document.getElementById("edit_class_group").style.display = "flex";
                document.getElementById("edit_class").required = true;
                document.getElementById("edit_class").value = user.class_id || "";
            } else {
                document.getElementById("edit_class_group").style.display = "none";
                document.getElementById("edit_class").required = false;
            }
            document.getElementById("editUserModal").style.display = "flex";
        }
        async function addUser(event) {
            event.preventDefault();
            const res = await fetch("/api/admin/users", {
                method: "POST", headers: { "Content-Type": "application/json" },
                body: JSON.stringify(Object.fromEntries(new FormData(event.target))),
            });
            const result = await res.json();
            if (res.ok) { alert("Felhasználó sikeresen létrehozva!"); closeModal('addUserModal'); location.reload(); }
            else alert(result.error || "Hiba történt");
        }
        async function updateUser(event) {
            event.preventDefault();
            const userId = document.getElementById("edit_user_id").value;
            const res = await fetch('/api/admin/users/' + userId, {
                method: "PUT", headers: { "Content-Type": "application/json" },
                body: JSON.stringify(Object.fromEntries(new FormData(event.target))),
            });
            const result = await res.json();
            if (res.ok) { alert("Felhasználó sikeresen frissítve!"); closeModal('editUserModal'); location.reload(); }
            else alert(result.error || "Hiba történt");
        }
        async function deleteUser(userId, username) {
            if (!confirm('Biztosan törölni szeretnéd: ' + username + '?')) return;
            const res = await fetch('/api/admin/users/' + userId, { method: "DELETE" });
            const result = await res.json();
            if (res.ok) { alert("Felhasználó sikeresen törölve!"); location.reload(); }
            else alert(result.error || "Hiba történt");
        }
    </script>
</body>
</html>