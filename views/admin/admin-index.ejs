<!DOCTYPE html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="stylesheet" href="/css/admin/admin-index.css" />
		<title>Admin Felület - Elektronikus tanulmányi rendszer</title>
	</head>
	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="logo-section">
						<img src="/icons/icon-128.webp" alt="Iskola logo" />
					</div>
					<div class="user-info">
						<span>Bejelentkezve: <%= first_name %> </span>
						<a href="/logout" class="logout-btn">
							<img src="/icons/logouticon.svg" alt="Kijelentkezés" title="Kijelentkezés" />
						</a>
					</div>
				</div>
			</div>
		</header>

		<main class="container">
			<section class="stats-section">
				<h2>Statisztikák</h2>
				<div class="stats-grid">
					<div class="stat-card">
						<div class="stat-icon">👥</div>
						<div class="stat-info">
							<h3><%= stats.totalUsers %></h3>
							<p>Összes felhasználó</p>
						</div>
					</div>
					<div class="stat-card">
						<div class="stat-icon">🎓</div>
						<div class="stat-info">
							<h3><%= stats.students %></h3>
							<p>Diákok</p>
						</div>
					</div>
					<div class="stat-card">
						<div class="stat-icon">👨‍🏫</div>
						<div class="stat-info">
							<h3><%= stats.teachers %></h3>
							<p>Tanárok</p>
						</div>
					</div>
					<div class="stat-card">
						<div class="stat-icon">⚙️</div>
						<div class="stat-info">
							<h3><%= stats.admins %></h3>
							<p>Adminisztrátorok</p>
						</div>
					</div>
				</div>
			</section>

			<div class="content-grid">
				<section class="users-section">
					<div class="section-header">
						<h2>Felhasználó kezelés</h2>
						<button class="btn-primary" onclick="openAddUserModal()"><span>➕</span> Új felhasználó</button>
					</div>

					<div class="table-container">
						<table class="users-table">
							<thead>
								<tr>
									<th>ID</th>
									<th>Felhasználónév</th>
									<th>Név</th>
									<th>Email</th>
									<th>Szerepkör</th>
									<th>Műveletek</th>
								</tr>
							</thead>
							<tbody>
								<% users.forEach(user => { %>
								<tr>
									<td><%= user.id %></td>
									<td><%= user.username %></td>
									<td><%= user.last_name %> <%= user.first_name %></td>
									<td><%= user.email || '-' %></td>
									<td>
										<span class="role-badge role-<%= user.role %>">
											<% if (user.role === 'student') { %> 🎓 Diák
											<% } else if (user.role === 'teacher') { %> 👨‍🏫 Tanár
											<% } else if (user.role === 'admin') { %> ⚙️ Admin
											<% } %>
										</span>
									</td>
									<td class="action-buttons">
										<button class="btn-edit" onclick="openEditUserModal(<%= user.id %>)" title="Szerkesztés">✏️</button>
										<button class="btn-delete" onclick="deleteUser(<%= user.id %>, '<%= user.username %>')" title="Törlés">🗑️</button>
									</td>
								</tr>
								<% }); %>
							</tbody>
						</table>
					</div>
				</section>

				<section class="classes-section">
					<div class="section-header">
						<h2>Osztály kezelés</h2>
						<button class="btn-primary" onclick="openAddClassModal()"><span>➕</span> Új osztály</button>
					</div>

					<div class="table-container">
						<table class="users-table">
							<thead>
								<tr>
									<th>ID</th>
									<th>Osztály neve</th>
									<th>Tanév</th>
									<th>Osztályfőnök</th>
									<th>Terem</th>
								</tr>
							</thead>
							<tbody>
								<% classes.forEach(cls => { %>
								<tr>
									<td><%= cls.id %></td>
									<td><%= cls.class_name %></td>
									<td><%= cls.academic_year %></td>
									<td><%= cls.users ? cls.users.last_name + ' ' + cls.users.first_name : '-' %></td>
									<td><%= cls.room_number || '-' %></td>
								</tr>
								<% }); %>
							</tbody>
						</table>
					</div>
				</section>
			</div>
		</main>

		<!-- Add User Modal -->
		<div id="addUserModal" class="modal">
			<div class="modal-content">
				<div class="modal-header">
					<h3>Új felhasználó hozzáadása</h3>
					<button class="close-btn" onclick="closeAddUserModal()">&times;</button>
				</div>
				<form id="addUserForm" onsubmit="addUser(event)">
					<div class="form-group">
						<label for="add_username">Felhasználónév *</label>
						<input type="text" id="add_username" name="username" required />
					</div>
					<div class="form-group">
						<label for="add_password">Jelszó *</label>
						<input type="password" id="add_password" name="password" required />
					</div>
					<div class="form-row">
						<div class="form-group">
							<label for="add_first_name">Keresztnév *</label>
							<input type="text" id="add_first_name" name="first_name" required />
						</div>
						<div class="form-group">
							<label for="add_last_name">Vezetéknév *</label>
							<input type="text" id="add_last_name" name="last_name" required />
						</div>
					</div>
					<div class="form-group">
						<label for="add_email">Email</label>
						<input type="email" id="add_email" name="email" />
					</div>
					<div class="form-group">
						<label for="add_role">Szerepkör *</label>
						<select id="add_role" name="role" required onchange="toggleClassSelector('add')">
							<option value="">Válassz...</option>
							<option value="student">Diák</option>
							<option value="teacher">Tanár</option>
							<option value="admin">Admin</option>
						</select>
					</div>
					<div class="form-group" id="add_class_group" style="display: none;">
						<label for="add_class">Osztály *</label>
						<select id="add_class" name="class_id">
							<option value="">Válassz osztályt...</option>
							<% classes.forEach(cls => { %>
							<option value="<%= cls.id %>"><%= cls.class_name %></option>
							<% }); %>
						</select>
					</div>
					<div class="form-actions">
						<button type="button" class="btn-secondary" onclick="closeAddUserModal()">Mégse</button>
						<button type="submit" class="btn-primary">Létrehozás</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Edit User Modal -->
		<div id="editUserModal" class="modal">
			<div class="modal-content">
				<div class="modal-header">
					<h3>Felhasználó szerkesztése</h3>
					<button class="close-btn" onclick="closeEditUserModal()">&times;</button>
				</div>
				<form id="editUserForm" onsubmit="updateUser(event)">
					<input type="hidden" id="edit_user_id" />
					<div class="form-group">
						<label for="edit_username">Felhasználónév *</label>
						<input type="text" id="edit_username" name="username" required />
					</div>
					<div class="form-group">
						<label for="edit_password">Új jelszó (üresen hagyva nem változik)</label>
						<input type="password" id="edit_password" name="password" />
					</div>
					<div class="form-row">
						<div class="form-group">
							<label for="edit_first_name">Keresztnév *</label>
							<input type="text" id="edit_first_name" name="first_name" required />
						</div>
						<div class="form-group">
							<label for="edit_last_name">Vezetéknév *</label>
							<input type="text" id="edit_last_name" name="last_name" required />
						</div>
					</div>
					<div class="form-group">
						<label for="edit_email">Email *</label>
						<input type="email" id="edit_email" name="email" />
					</div>
					<div class="form-group">
						<label for="edit_role">Szerepkör *</label>
						<select id="edit_role" name="role" required onchange="toggleClassSelector('edit')">
							<option value="student">Diák</option>
							<option value="teacher">Tanár</option>
							<option value="admin">Admin</option>
						</select>
					</div>
					<div class="form-group" id="edit_class_group" style="display: none;">
						<label for="edit_class">Osztály *</label>
						<select id="edit_class" name="class_id">
							<option value="">Válassz osztályt...</option>
							<% classes.forEach(cls => { %>
							<option value="<%= cls.id %>"><%= cls.class_name %></option>
							<% }); %>
						</select>
					</div>
					<div class="form-actions">
						<button type="button" class="btn-secondary" onclick="closeEditUserModal()">Mégse</button>
						<button type="submit" class="btn-primary">Mentés</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Add Class Modal -->
		<div id="addClassModal" class="modal">
			<div class="modal-content">
				<div class="modal-header">
					<h3>Új osztály létrehozása</h3>
					<button class="close-btn" onclick="closeAddClassModal()">&times;</button>
				</div>
				<form id="addClassForm" onsubmit="addClass(event)">
					<div class="form-group">
						<label for="class_name">Osztály neve *</label>
						<input type="text" id="class_name" name="class_name" placeholder="pl. 9.A" required />
					</div>
					<div class="form-group">
						<label for="academic_year">Tanév *</label>
						<input type="text" id="academic_year" name="academic_year" placeholder="2024/2025" required />
					</div>
					<div class="form-group">
						<label for="class_teacher_id">Osztályfőnök</label>
						<select id="class_teacher_id" name="class_teacher_id">
							<option value="">Nincs megadva</option>
							<% teachers.forEach(t => { %>
							<option value="<%= t.id %>"><%= t.last_name %> <%= t.first_name %></option>
							<% }); %>
						</select>
					</div>
					<div class="form-group">
						<label for="room_number">Terem</label>
						<input type="text" id="room_number" name="room_number" placeholder="pl. 101" />
					</div>
					<div class="form-actions">
						<button type="button" class="btn-secondary" onclick="closeAddClassModal()">Mégse</button>
						<button type="submit" class="btn-primary">Létrehozás</button>
					</div>
				</form>
			</div>
		</div>

		<script>
			function toggleClassSelector(mode) {
				const roleSelect = document.getElementById(`${mode}_role`);
				const classGroup = document.getElementById(`${mode}_class_group`);
				const classSelect = document.getElementById(`${mode}_class`);

				if (roleSelect.value === 'student') {
					classGroup.style.display = 'flex';
					classSelect.required = true;
				} else {
					classGroup.style.display = 'none';
					classSelect.required = false;
					classSelect.value = '';
				}
			}

			function openAddUserModal() {
				document.getElementById("addUserModal").style.display = "flex";
			}

			function closeAddUserModal() {
				document.getElementById("addUserModal").style.display = "none";
				document.getElementById("addUserForm").reset();
				document.getElementById("add_class_group").style.display = "none";
			}

			async function openEditUserModal(userId) {
				try {
					const response = await fetch(`/api/admin/users/${userId}`);
					const user = await response.json();

					if (response.ok) {
						document.getElementById("edit_user_id").value = user.id;
						document.getElementById("edit_username").value = user.username;
						document.getElementById("edit_first_name").value = user.first_name;
						document.getElementById("edit_last_name").value = user.last_name;
						document.getElementById("edit_email").value = user.email || "";
						document.getElementById("edit_role").value = user.role;
						document.getElementById("edit_password").value = "";

						if (user.role === 'student') {
							document.getElementById("edit_class_group").style.display = "flex";
							document.getElementById("edit_class").required = true;
							document.getElementById("edit_class").value = user.class_id || "";
						} else {
							document.getElementById("edit_class_group").style.display = "none";
							document.getElementById("edit_class").required = false;
						}

						document.getElementById("editUserModal").style.display = "flex";
					} else {
						alert("Hiba történt a felhasználó betöltésekor");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt a felhasználó betöltésekor");
				}
			}

			function closeEditUserModal() {
				document.getElementById("editUserModal").style.display = "none";
				document.getElementById("editUserForm").reset();
				document.getElementById("edit_class_group").style.display = "none";
			}

			async function addUser(event) {
				event.preventDefault();
				const formData = new FormData(event.target);
				const data = Object.fromEntries(formData);

				try {
					const response = await fetch("/api/admin/users", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(data),
					});

					const result = await response.json();

					if (response.ok) {
						alert("Felhasználó sikeresen létrehozva!");
						closeAddUserModal();
						location.reload();
					} else {
						alert(result.error || "Hiba történt a felhasználó létrehozásakor");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt a felhasználó létrehozásakor");
				}
			}

			async function updateUser(event) {
				event.preventDefault();
				const userId = document.getElementById("edit_user_id").value;
				const formData = new FormData(event.target);
				const data = Object.fromEntries(formData);

				try {
					const response = await fetch(`/api/admin/users/${userId}`, {
						method: "PUT",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(data),
					});

					const result = await response.json();

					if (response.ok) {
						alert("Felhasználó sikeresen frissítve!");
						closeEditUserModal();
						location.reload();
					} else {
						alert(result.error || "Hiba történt a felhasználó frissítésekor");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt a felhasználó frissítésekor");
				}
			}

			async function deleteUser(userId, username) {
				if (!confirm(`Biztosan törölni szeretnéd ezt a felhasználót: ${username}?`)) {
					return;
				}

				try {
					const response = await fetch(`/api/admin/users/${userId}`, {
						method: "DELETE",
					});

					const result = await response.json();

					if (response.ok) {
						alert("Felhasználó sikeresen törölve!");
						location.reload();
					} else {
						alert(result.error || "Hiba történt a felhasználó törlésekor");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt a felhasználó törlésekor");
				}
			}

			function openAddClassModal() {
				document.getElementById("addClassModal").style.display = "flex";
			}

			function closeAddClassModal() {
				document.getElementById("addClassModal").style.display = "none";
				document.getElementById("addClassForm").reset();
			}

			async function addClass(event) {
				event.preventDefault();
				const formData = new FormData(event.target);
				const data = Object.fromEntries(formData);

				try {
					const response = await fetch("/api/admin/classes", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(data),
					});

					const result = await response.json();

					if (response.ok) {
						alert("Osztály sikeresen létrehozva!");
						closeAddClassModal();
						location.reload();
					} else {
						alert(result.error || "Hiba történt az osztály létrehozásakor");
					}
				} catch (error) {
					console.error("Hiba:", error);
					alert("Hiba történt az osztály létrehozásakor");
				}
			}

			window.onclick = function (event) {
				const addModal = document.getElementById("addUserModal");
				const editModal = document.getElementById("editUserModal");
				const addClassModal = document.getElementById("addClassModal");
				if (event.target === addModal) closeAddUserModal();
				if (event.target === editModal) closeEditUserModal();
				if (event.target === addClassModal) closeAddClassModal();
			};
		</script>
	</body>
</html>